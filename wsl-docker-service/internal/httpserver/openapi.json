{
  "openapi": "3.0.3",
  "info": {
    "title": "docklite-wsl",
    "description": "HTTP API cho DockLite (Docker/Compose trong WSL). Khi biến môi trường DOCKLITE_API_TOKEN khác rỗng, mọi yêu cầu cần header Authorization: Bearer <token> hoặc X-DockLite-Token. Header tùy chọn X-Request-ID (chuẩn hóa trên server): client gửi ID tương quan; response trả cùng giá trị; log slog dùng req_id. WebSocket: giới hạn số kết nối đồng thời bằng DOCKLITE_WS_MAX_CONNECTIONS (mặc định 64). Tài liệu này mô tả route và phương thức; chi tiết body/query xem mã nguồn và README.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Tương đối ServiceBaseUrl (ví dụ http://127.0.0.1:17890/)"
    }
  ],
  "tags": [
    { "name": "system", "description": "Metrics, health, schema" },
    { "name": "docker", "description": "Container, image, network, volume, prune" },
    { "name": "compose", "description": "Compose projects và service; mỗi project tối đa 16 file -f (đường dẫn tương đối trong thư mục project, mỗi dòng một file)" },
    { "name": "websocket", "description": "Luồng log và stats" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "opaque",
        "description": "Khớp DOCKLITE_API_TOKEN khi bật xác thực"
      },
      "dockLiteToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-DockLite-Token",
        "description": "Thay thế tùy chọn cho Bearer"
      }
    },
    "schemas": {
      "ComposeIdBody": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "ID project Compose đã lưu (UUID)"
          },
          "profiles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tùy chọn: lặp lại `docker compose --profile <tên>` (tối đa 32 profile, mỗi tên tối đa 128 ký tự)"
          }
        }
      },
      "ComposeServiceBody": {
        "type": "object",
        "required": ["id", "service"],
        "properties": {
          "id": { "type": "string" },
          "service": { "type": "string" },
          "profiles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tùy chọn: compose --profile"
          }
        }
      },
      "ComposeServiceLogsBody": {
        "type": "object",
        "required": ["id", "service"],
        "properties": {
          "id": { "type": "string" },
          "service": { "type": "string" },
          "tail": { "type": "integer", "default": 200, "description": "Số dòng tail (1–10000)" },
          "profiles": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "ComposeServiceExecBody": {
        "type": "object",
        "required": ["id", "service", "command"],
        "properties": {
          "id": { "type": "string" },
          "service": { "type": "string" },
          "command": { "type": "string", "description": "Lệnh tách bằng khoảng trắng (exec -T)" },
          "profiles": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "ImageTrivyScanBody": {
        "type": "object",
        "required": ["imageRef"],
        "properties": {
          "imageRef": {
            "type": "string",
            "description": "Tham chiếu image đầy đủ (ví dụ nginx:alpine). Cần binary `trivy` trong PATH trên WSL."
          },
          "format": {
            "type": "string",
            "description": "Định dạng đầu ra: `table` (mặc định) hoặc `json`. Giá trị khác được chuẩn hóa thành table."
          },
          "policyPath": {
            "type": "string",
            "description": "Đường dẫn tuyệt đối trong WSL tới policy Rego (tùy chọn, `trivy image --policy`). Không chứa `..` hoặc ký tự shell."
          }
        }
      },
      "WslHostResourcesDto": {
        "type": "object",
        "description": "Snapshot tài nguyên Linux phía tiến trình service (WSL distro): bộ nhớ, load, đĩa gốc.",
        "properties": {
          "memoryTotalKb": { "type": "integer", "format": "int64" },
          "memoryAvailableKb": { "type": "integer", "format": "int64" },
          "memoryUsedPercent": { "type": "number", "format": "double" },
          "loadAvg1": { "type": "number", "format": "double" },
          "loadAvg5": { "type": "number", "format": "double" },
          "loadAvg15": { "type": "number", "format": "double" },
          "rootMountPath": { "type": "string" },
          "diskRootTotalBytes": { "type": "integer", "format": "int64" },
          "diskRootAvailableBytes": { "type": "integer", "format": "int64" },
          "diskRootUsedPercent": { "type": "number", "format": "double" },
          "hostname": { "type": "string" },
          "cpuCoresOnline": { "type": "integer" },
          "collectedAtUtcIso": { "type": "string" }
        }
      },
      "AuthRotateRequest": {
        "type": "object",
        "required": ["current_token"],
        "properties": {
          "current_token": {
            "type": "string",
            "description": "Mật khẩu Bearer hiện tại (phải khớp với token trên server)"
          }
        }
      },
      "AuthRotateData": {
        "type": "object",
        "required": ["new_token"],
        "properties": {
          "new_token": {
            "type": "string",
            "description": "Mật khẩu mới (process cập nhật RAM; đồng bộ DOCKLITE_API_TOKEN/DockLite khi khởi động lại service)"
          }
        }
      }
    },
    "responses": {
      "OkEnvelope": {
        "description": "Thành công (envelope JSON apiresponse)",
        "content": {
          "application/json": {
            "schema": { "type": "object" }
          }
        }
      },
      "Unauthorized": {
        "description": "Thiếu hoặc sai token khi DOCKLITE_API_TOKEN được đặt"
      }
    }
  },
  "paths": {
    "/api/openapi.json": {
      "get": {
        "tags": ["system"],
        "summary": "Tài liệu OpenAPI 3.0 (chính tệp này)",
        "responses": {
          "200": {
            "description": "OpenAPI JSON",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/api/metrics": {
      "get": {
        "tags": ["system"],
        "summary": "Số đếm request đơn giản (text/plain)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["system"],
        "summary": "Health và phiên bản service",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/auth/rotate": {
      "post": {
        "tags": ["system"],
        "summary": "Xoay mật khẩu API (Bearer)",
        "description": "Chỉ đăng ký khi DOCKLITE_API_TOKEN khác rỗng lúc khởi động. Giới hạn khoảng 5 yêu cầu/phút theo IP.",
        "security": [{ "bearerAuth": [] }, { "dockLiteToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRotateRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/OkEnvelope" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "description": "Xác thực API chưa bật trên service" },
          "429": { "description": "Quá nhiều yêu cầu xoay token" }
        }
      }
    },
    "/api/wsl/host-resources": {
      "get": {
        "tags": ["system"],
        "summary": "Tài nguyên máy phía WSL (RAM, load, đĩa gốc)",
        "description": "Đọc /proc/meminfo, /proc/loadavg và statfs trên mount gốc — không gọi Docker Engine.",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/docker/info": {
      "get": {
        "tags": ["docker"],
        "summary": "docker info",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/docker/events/stream": {
      "get": {
        "tags": ["docker"],
        "summary": "Luồng sự kiện Docker Engine (NDJSON)",
        "description": "Mỗi dòng một đối tượng JSON (sự kiện từ Docker API). Content-Type: application/x-ndjson. Kết nối có thể mở lâu; client nên hủy khi không cần. Không dùng envelope apiresponse.",
        "responses": {
          "200": {
            "description": "Luồng NDJSON (một sự kiện JSON mỗi dòng)",
            "content": {
              "application/x-ndjson": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "503": { "description": "Docker client không khởi tạo được" }
        }
      }
    },
    "/api/containers/top-by-memory": {
      "get": {
        "tags": ["docker"],
        "summary": "Top container theo RAM",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/top-by-cpu": {
      "get": {
        "tags": ["docker"],
        "summary": "Top container theo CPU",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/stats-batch": {
      "post": {
        "tags": ["docker"],
        "summary": "Stats nhiều container (JSON body ids)",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers": {
      "get": {
        "tags": ["docker"],
        "summary": "Liệt kê container",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/{id}": {
      "delete": {
        "tags": ["docker"],
        "summary": "Xóa container (query force)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/{id}/start": {
      "post": {
        "tags": ["docker"],
        "summary": "Start container",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/{id}/stop": {
      "post": {
        "tags": ["docker"],
        "summary": "Stop container",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/{id}/restart": {
      "post": {
        "tags": ["docker"],
        "summary": "Restart container",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/{id}/logs": {
      "get": {
        "tags": ["docker"],
        "summary": "Tail log (query tail)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/{id}/inspect": {
      "get": {
        "tags": ["docker"],
        "summary": "Inspect container",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/containers/{id}/stats": {
      "get": {
        "tags": ["docker"],
        "summary": "Snapshot stats một container",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/ws/containers/{id}/logs": {
      "get": {
        "tags": ["websocket"],
        "summary": "WebSocket stream docker logs -f",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "101": { "description": "Switching Protocols" },
          "503": { "description": "Đạt giới hạn kết nối WebSocket đồng thời (DOCKLITE_WS_MAX_CONNECTIONS)" }
        }
      }
    },
    "/ws/containers/{id}/stats": {
      "get": {
        "tags": ["websocket"],
        "summary": "WebSocket stream docker stats (query intervalMs)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "101": { "description": "Switching Protocols" },
          "503": { "description": "Đạt giới hạn kết nối WebSocket đồng thời (DOCKLITE_WS_MAX_CONNECTIONS)" }
        }
      }
    },
    "/api/compose/projects": {
      "get": {
        "tags": ["compose"],
        "summary": "Danh sách project đã lưu",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      },
      "post": {
        "tags": ["compose"],
        "summary": "Thêm project",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/projects/{id}": {
      "delete": {
        "tags": ["compose"],
        "summary": "Xóa project",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      },
      "patch": {
        "tags": ["compose"],
        "summary": "Sửa project (compose files, tên, …)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/up": {
      "post": {
        "tags": ["compose"],
        "summary": "compose up",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeIdBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/down": {
      "post": {
        "tags": ["compose"],
        "summary": "compose down",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeIdBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/ps": {
      "post": {
        "tags": ["compose"],
        "summary": "compose ps",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeIdBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/config/services": {
      "post": {
        "tags": ["compose"],
        "summary": "Liệt kê service từ compose config",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeIdBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/config/validate": {
      "post": {
        "tags": ["compose"],
        "summary": "Kiểm tra compose (docker compose config -q)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeIdBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/service/start": {
      "post": {
        "tags": ["compose"],
        "summary": "Start một service",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeServiceBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/service/stop": {
      "post": {
        "tags": ["compose"],
        "summary": "Stop một service",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeServiceBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/service/logs": {
      "post": {
        "tags": ["compose"],
        "summary": "Log service (một lần)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeServiceLogsBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/compose/service/exec": {
      "post": {
        "tags": ["compose"],
        "summary": "Exec lệnh trong service",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ComposeServiceExecBody" }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images": {
      "get": {
        "tags": ["docker"],
        "summary": "Liệt kê image",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images/pull": {
      "post": {
        "tags": ["docker"],
        "summary": "docker pull",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images/pull/stream": {
      "post": {
        "tags": ["docker"],
        "summary": "docker pull — luồng thô (không envelope JSON)",
        "responses": { "200": { "description": "Luồng từ Docker ImagePull" } }
      }
    },
    "/api/images/trivy-scan": {
      "post": {
        "tags": ["docker"],
        "summary": "Quét CVE bằng Trivy (tùy chọn)",
        "description": "Gọi `trivy image` trên WSL. Trả envelope JSON khi thành công (data.output, data.format). 503 nếu không tìm thấy `trivy` trong PATH.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImageTrivyScanBody" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/OkEnvelope" },
          "503": { "description": "Không có trivy trong PATH hoặc lỗi tương đương" }
        }
      }
    },
    "/api/images/load": {
      "post": {
        "tags": ["docker"],
        "summary": "docker load (tar)",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images/prune": {
      "post": {
        "tags": ["docker"],
        "summary": "docker image prune",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images/remove": {
      "post": {
        "tags": ["docker"],
        "summary": "docker rmi",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images/{id}/inspect": {
      "get": {
        "tags": ["docker"],
        "summary": "Inspect image",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images/{id}/history": {
      "get": {
        "tags": ["docker"],
        "summary": "History image",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/images/{id}/export": {
      "get": {
        "tags": ["docker"],
        "summary": "docker save (tar)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "application/x-tar" } }
      }
    },
    "/api/networks": {
      "get": {
        "tags": ["docker"],
        "summary": "Liệt kê network",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/volumes": {
      "get": {
        "tags": ["docker"],
        "summary": "Liệt kê volume",
        "responses": { "200": { "$ref": "#/components/responses/OkEnvelope" } }
      }
    },
    "/api/volumes/remove": {
