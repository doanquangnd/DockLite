<Window x:Class="DockLite.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DockLite.App.ViewModels"
        xmlns:views="clr-namespace:DockLite.App.Views"
        mc:Ignorable="d"
        Title="DockLite"
        Height="640"
        Width="960"
        MinHeight="480"
        MinWidth="720">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#F3F3F3"
                BorderBrush="#DDD"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="DockLite"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="16,20,16,12" />
                <StackPanel Margin="8,0,8,16">
                    <Button Content="Tổng quan"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateDashboardCommand}" />
                    <Button Content="Container"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateContainersCommand}" />
                    <Button Content="Log"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateLogsCommand}" />
                    <Button Content="Compose"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateComposeCommand}" />
                    <Button Content="Image"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateImagesCommand}" />
                    <Button Content="Dọn dẹp"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateCleanupCommand}" />
                    <Button Content="Nhật ký ứng dụng"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateAppDebugLogCommand}" />
                    <Button Content="Cài đặt"
                            Margin="0,4"
                            Padding="12,8"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NavigateSettingsCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Margin="20"
                        Content="{Binding CurrentPage}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:ContainersViewModel}">
                    <views:ContainersView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:LogsViewModel}">
                    <views:LogsView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ComposeViewModel}">
                    <views:ComposeView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ImagesViewModel}">
                    <views:ImagesView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:CleanupViewModel}">
                    <views:CleanupView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AppDebugLogViewModel}">
                    <views:AppDebugLogView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
