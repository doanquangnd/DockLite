<Window x:Class="DockLite.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DockLite.App.ViewModels"
        xmlns:views="clr-namespace:DockLite.App.Views"
        mc:Ignorable="d"
        Title="{DynamicResource Ui_MainWindow_Title}"
        Height="680"
        Width="1024"
        MinHeight="520"
        MinWidth="760"
        Background="{DynamicResource WindowBackgroundBrush}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable, Segoe UI">
    <Window.InputBindings>
        <KeyBinding Key="F5"
                    Command="{Binding RefreshCurrentPageCommand}" />
        <KeyBinding Modifiers="Control"
                    Key="F"
                    Command="{Binding FocusPrimarySearchCommand}" />
        <KeyBinding Modifiers="Control"
                    Key="D1"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="1" />
        <KeyBinding Modifiers="Control"
                    Key="D2"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="2" />
        <KeyBinding Modifiers="Control"
                    Key="D3"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="3" />
        <KeyBinding Modifiers="Control"
                    Key="D4"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="4" />
        <KeyBinding Modifiers="Control"
                    Key="D5"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="5" />
        <KeyBinding Modifiers="Control"
                    Key="D6"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="6" />
        <KeyBinding Modifiers="Control"
                    Key="D7"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="7" />
        <KeyBinding Modifiers="Control"
                    Key="D8"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="8" />
        <KeyBinding Modifiers="Control"
                    Key="D9"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="9" />
        <KeyBinding Modifiers="Control"
                    Key="D0"
                    Command="{Binding NavigateSidebarByIndexCommand}"
                    CommandParameter="10" />
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header chung: trạng thái service WSL (góc phải) -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,12,26,12"
                Effect="{DynamicResource DockLiteSubtleHeaderShadow}"
                ToolTip="{DynamicResource Ui_Tooltip_Header_Bar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Margin="0,0,6,0"
                            Padding="10,6"
                            MinWidth="72"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Ui_Header_Start}"
                            Command="{Binding HeaderStartWslServiceCommand}"
                            IsEnabled="{Binding CanHeaderStartWslService}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="{DynamicResource Ui_Tooltip_Header_Start}" />
                    <Button Margin="0,0,6,0"
                            Padding="10,6"
                            MinWidth="72"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Ui_Header_Stop}"
                            Command="{Binding HeaderStopWslServiceCommand}"
                            IsEnabled="{Binding CanHeaderStopWslService}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="{DynamicResource Ui_Tooltip_Header_Stop}" />
                    <Button Margin="0,0,12,0"
                            Padding="10,6"
                            MinWidth="84"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Ui_Header_Restart}"
                            Command="{Binding HeaderRestartWslServiceCommand}"
                            IsEnabled="{Binding CanHeaderRestartWslService}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="{DynamicResource Ui_Tooltip_Header_Restart}" />
                    <Button Margin="0,0,16,0"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Ui_Header_Help}"
                            Command="{Binding ShowHelpCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="{DynamicResource Ui_Tooltip_Header_Help}" />
                        <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                Text="{DynamicResource Ui_Header_StatusPrefix}" />
                            <TextBlock Margin="0,0,12,0"
                                    FontSize="13"
                                    Foreground="{DynamicResource ThemeBodyTextBrush}"
                                    Text="{Binding ServiceHeaderPrimaryText}"
                                    TextAlignment="Right"
                                    TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                    Text="{Binding ServiceHeaderSecondaryText}"
                                    TextAlignment="Right"
                                    Visibility="{Binding HasServiceHeaderSecondary, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                </StackPanel>
                <ProgressBar Grid.Row="1"
                             Width="280"
                             Height="5"
                             Margin="0,8,0,0"
                             HorizontalAlignment="Right"
                             Maximum="100"
                             Value="{Binding WslStartupProgressBarValue}"
                             IsIndeterminate="{Binding WslStartupProgressBarIndeterminate}"
                             Visibility="{Binding WslStartupProgressBarVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                             ToolTip="{DynamicResource Ui_Tooltip_Header_ProgressBar}" />
            </Grid>
        </Border>

        <!-- Banner: mất kết nối service (một chỗ thay vì chỉ lỗi rải rác trên nút) -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Padding="18,8,22,8"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeWarningForegroundBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowServiceDisconnectedBanner, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="{DynamicResource Ui_Shell_ServiceDisconnectedBanner}" />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                               Text="{DynamicResource Ui_Shell_ServiceDisconnectedBannerHint}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Padding="12,6"
                            MinWidth="120"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="{DynamicResource Ui_Shell_OpenSettingsConnection}"
                            Command="{Binding OpenSettingsConnectionFromBannerCommand}" />
                    <Button Padding="12,6"
                            MinWidth="100"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="{DynamicResource Ui_Shell_RetryServiceConnection}"
                            Command="{Binding RetryServiceConnectionCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Thanh bên -->
        <Border Grid.Row="2"
                Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource SidebarEdgeBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top"
                            Margin="22,30,18,20">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10"
                                 Height="10"
                                 Margin="0,6,10,0"
                                 VerticalAlignment="Top"
                                 Fill="{Binding SidebarConnectionDotFill}"
                                 ToolTip="{DynamicResource Ui_Sidebar_ConnectionTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Sidebar_Title}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource NavForegroundBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12.5"
                               Foreground="{StaticResource NavLabelMutedBrush}"
                               Text="{DynamicResource Ui_Sidebar_Subtitle}"
                               TextWrapping="Wrap" />
                    <Border Height="1"
                            Margin="0,18,0,0"
                            Background="{DynamicResource SidebarDividerBrush}"
                            Opacity="0.9" />
                </StackPanel>
                <StackPanel Margin="12,0,14,22"
                            ToolTip="{DynamicResource Ui_Tooltip_Sidebar_Nav}">
                    <Button Content="{DynamicResource Ui_Nav_Dashboard}"
                            Style="{StaticResource NavShellDashboardStyle}"
                            Command="{Binding NavigateDashboardCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_Containers}"
                            Style="{StaticResource NavShellContainersStyle}"
                            Command="{Binding NavigateContainersCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_Logs}"
                            Style="{StaticResource NavShellLogsStyle}"
                            Command="{Binding NavigateLogsCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_Compose}"
                            Style="{StaticResource NavShellComposeStyle}"
                            Command="{Binding NavigateComposeCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_Images}"
                            Style="{StaticResource NavShellImagesStyle}"
                            Command="{Binding NavigateImagesCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_NetworkVolume}"
                            Style="{StaticResource NavShellNetworkVolumeStyle}"
                            Command="{Binding NavigateNetworkVolumeCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_Cleanup}"
                            Style="{StaticResource NavShellCleanupStyle}"
                            Command="{Binding NavigateCleanupCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_DockerEvents}"
                            Style="{StaticResource NavShellDockerEventsStyle}"
                            Command="{Binding NavigateDockerEventsCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_AppLog}"
                            Style="{StaticResource NavShellAppLogStyle}"
                            Command="{Binding NavigateAppDebugLogCommand}" />
                    <Button Content="{DynamicResource Ui_Nav_Settings}"
                            Style="{StaticResource NavShellSettingsStyle}"
                            Command="{Binding NavigateSettingsCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Vùng nội dung -->
        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{DynamicResource ContentBackgroundBrush}">
            <ScrollViewer x:Name="MainContentScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          PanningMode="VerticalOnly"
                          IsDeferredScrollingEnabled="True"
                          Padding="32,28,36,32">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                            <views:DashboardView />
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type vm:ContainersViewModel}">
                            <views:ContainersView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
                            <views:LogsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ComposeViewModel}">
                            <views:ComposeView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ImagesViewModel}">
                            <views:ImagesView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:NetworkVolumeViewModel}">
                            <views:NetworkVolumeView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:CleanupViewModel}">
                            <views:CleanupView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:DockerEventsViewModel}">
                            <views:DockerEventsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:AppDebugLogViewModel}">
                            <views:AppDebugLogView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </ScrollViewer>
        </Border>

        <!-- Toast: luôn trong client area, theo cửa sổ (đa màn hình / thu nhỏ) -->
        <Grid Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              Panel.ZIndex="4000"
              IsHitTestVisible="False">
            <StackPanel x:Name="ToastStackPanel"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,20"
                        MaxWidth="520"
                        IsHitTestVisible="True" />
        </Grid>
    </Grid>
</Window>
