<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Gộp sau ModernTheme: ghi đè brush cho vùng nội dung, thẻ và accent. -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemePageTitleBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="ThemeDataGridAlternatingRowBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ThemeDataGridRowBackgroundBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="ThemeDataGridRowHoverBackgroundBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeDataGridRowSelectedBackgroundBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="ThemeDataGridRowSelectedForegroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="ThemeListBoxItemSelectedBackgroundBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeListBoxItemSelectedForegroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="ThemeSecondaryButtonPressedBrush" Color="#475569" />
    <SolidColorBrush x:Key="ThemeSeparatorBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeBodyTextBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#334155" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#475569" />
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#64748B" />
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#F8FAFC" />

    <SolidColorBrush x:Key="ThemeControlForegroundBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="ThemeInputForegroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeInputCaretBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="ThemeInputSelectionBrush" Color="#075985" />
    <SolidColorBrush x:Key="ThemeInputReadOnlyBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ThemeInputDisabledForegroundBrush" Color="#64748B" />
    <SolidColorBrush x:Key="ThemeInputDisabledBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ThemeMutedForegroundBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="ThemeWarningForegroundBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="ThemeDangerForegroundBrush" Color="#F87171" />
    <SolidColorBrush x:Key="ThemeCodeBlockForegroundBrush" Color="#CBD5E1" />

    <SolidColorBrush x:Key="ThemeTabInactiveBackgroundBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="ThemeTabInactiveBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeTabInactiveForegroundBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="ThemeTabHoverBackgroundBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeTabSelectedForegroundBrush" Color="#F8FAFC" />

    <SolidColorBrush x:Key="ThemeProgressTrackBrush" Color="#334155" />

    <!-- DataGrid: header và lưới đọc rõ trên nền tối -->
    <SolidColorBrush x:Key="ThemeDataGridHorizontalGridLineBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeDataGridHeaderBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ThemeDataGridHeaderForegroundBrush" Color="#CBD5E1" />

    <!-- Sparkline: màu sáng hơn để tách khỏi nền -->
    <SolidColorBrush x:Key="ThemeSparklineCpuStrokeBrush" Color="#60A5FA" />
    <SolidColorBrush x:Key="ThemeSparklineMemStrokeBrush" Color="#34D399" />

    <SolidColorBrush x:Key="ThemeSuccessForegroundBrush" Color="#4ADE80" />
    <SolidColorBrush x:Key="ThemeDashboardEmphasisBrush" Color="#F1F5F9" />

    <SolidColorBrush x:Key="ThemeLogSeverityDefaultBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="ThemeLogSeverityErrorBrush" Color="#FCA5A5" />
    <SolidColorBrush x:Key="ThemeLogSeverityWarnBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="ThemeLogSeverityInfoBrush" Color="#7DD3FC" />
    <SolidColorBrush x:Key="ThemeLogSeverityDebugBrush" Color="#94A3B8" />

    <SolidColorBrush x:Key="ThemeComboBoxItemHoverBackgroundBrush" Color="#475569" />

    <SolidColorBrush x:Key="ThemeSurfaceSubtleBrush" Color="#0F172A" />

    <SolidColorBrush x:Key="ThemeScrollBarTrackBrush" Color="#334155" />
    <SolidColorBrush x:Key="ThemeScrollBarThumbBrush" Color="#64748B" />
    <SolidColorBrush x:Key="ThemeScrollBarThumbHoverBrush" Color="#94A3B8" />

    <!-- Sidebar: viền và vạch phân cách đồng bộ nền tối -->
    <SolidColorBrush x:Key="SidebarEdgeBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="SidebarDividerBrush" Color="#475569" />

    <!-- Sidebar: mục đang chọn -->
    <SolidColorBrush x:Key="NavRailActiveBackgroundBrush" Color="#475569" />

    <!-- Accent và nút chính nổi trên nền slate -->
    <SolidColorBrush x:Key="AccentBrush" Color="#38BDF8" />
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#0EA5E9" />
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#38BDF8" />
    <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#0284C7" />
    <SolidColorBrush x:Key="PrimaryButtonDisabledBrush" Color="#475569" />

    <!-- Đổ bóng header nhẹ trên nền tối -->
    <DropShadowEffect x:Key="DockLiteSubtleHeaderShadow"
                      BlurRadius="18"
                      ShadowDepth="0"
                      Opacity="0.12"
                      Direction="270"
                      Color="#000000" />
</ResourceDictionary>
