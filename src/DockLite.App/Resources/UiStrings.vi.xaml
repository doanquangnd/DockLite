    <sys:String x:Key="Ui_Settings_Display_LanguageLabel">Ngôn ngữ giao diện</sys:String>
    <sys:String x:Key="Ui_Settings_Display_LanguageTooltip">Tiếng Việt hoặc English. Lưu để áp dụng chuỗi vỏ cửa sổ và tên tab; nội dung chi tiết trong từng tab có thể vẫn một ngôn ngữ cho đến khi bổ sung đầy đủ bản dịch.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_ThemeLabel">Chủ đề giao diện</sys:String>
    <sys:String x:Key="Ui_Settings_Theme_Light">Sáng</sys:String>
    <sys:String x:Key="Ui_Settings_Theme_Dark">Tối</sys:String>
    <sys:String x:Key="Ui_Settings_Theme_System">Theo Windows</sys:String>
    <sys:String x:Key="Ui_Settings_Display_ThemeTooltip">Sáng, Tối hoặc Theo Windows (dùng chế độ sáng/tối ứng dụng của Windows). Lưu để ghi file và áp dụng từ điển tài nguyên; nếu một số màn hình chưa đổi, khởi động lại ứng dụng.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_TimeZoneLabel">Múi giờ hiển thị (ứng dụng)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_TimeZoneTooltip">Chọn «Giờ máy» để dùng múi giờ Windows hiện tại.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DateFormatLabel">Định dạng ngày giờ (chuỗi .NET)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DateFormatTooltip">Ví dụ: dd/MM/yyyy HH:mm:ss, G, g. Đổi sau khi Lưu mới áp dụng toàn app.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_PresetsLabel">Gợi ý nhanh</sys:String>
    <sys:String x:Key="Ui_Settings_Display_PreviewLabel">Xem trước</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DatePreviewPrefix">UTC hiện tại → </sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsAlertTitle">Cảnh báo tài nguyên (màn Container)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsAlertIntro">Khi bật stats realtime cho một container, nếu CPU hoặc RAM % (dùng/giới hạn) vượt ngưỡng thì hiển thị khối cảnh báo phía trên sparkline. Đặt 0 để tắt từng loại.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsCpuWarnLabel">Ngưỡng CPU % (0 = tắt)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsCpuWarnTooltip">Số nguyên 0–100. So với % CPU trong snapshot stats.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsMemWarnLabel">Ngưỡng RAM % (0 = tắt)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsMemWarnTooltip">Số nguyên 0–100. RAM % = dùng / giới hạn từ stats; nếu giới hạn = 0 thì không áp dụng cảnh báo RAM.</sys:String>

    <sys:String x:Key="Ui_Settings_Conn_LanSecurityBanner">Kết nối HTTP tới service không dùng TLS: trên LAN hoặc khi dùng IP, lưu lượng có thể bị nghe lén. Nếu trên WSL bật DOCKLITE_API_TOKEN, nhập cùng giá trị ở ô Token API bên dưới. Chi tiết: tài liệu «Bảo mật LAN» trong repo (docs/docklite-lan-security.md) hoặc nút mở tệp khi có trong thư mục source.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_LanSecurityOpenDoc">Mở tài liệu bảo mật LAN…</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_LanSecurityOpenDocTooltip">Mở tệp docklite-lan-security.md bằng ứng dụng mặc định (khi tệp có trong cây repo so với thư mục chạy).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_BaseUrlLabel">Địa chỉ base URL service (WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_BaseUrlTooltip">Mặc định http://127.0.0.1:17890/. Nếu Windows không kết nối được dù service đã chạy trong WSL, dùng nút bên phải để điền IP WSL.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApplyWslIp">Điền IP WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutLabel">Timeout HTTP (giây, 30–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutTooltip">Áp dụng cho mọi lệnh gọi REST (compose, prune có thể chạy lâu).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_CheckHint">Kiểm tra nhanh API + WSL (uname, wslpath) dùng khối bên dưới; hoặc nút «Kiểm tra kết nối» ở hàng dưới cùng (health + Docker).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckTitle">Kiểm tra môi trường (API + WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckIntro">Một lần chạy: checklist khôi phục kết nối, health, Docker Engine, uname trong distro, wslpath cho các đường dẫn đã nhập (giống tab WSL — chưa Lưu vẫn dùng giá trị ô).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckButton">Chạy kiểm tra API + WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckTooltip">Gọi cùng lệnh «Chẩn đoán nhanh» ở tab WSL; kết quả hiển thị ở đây và tab đó.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenLabel">Token API (tùy chọn, Bearer)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenTooltip">Nếu trên WSL đặt biến DOCKLITE_API_TOKEN cho docklite-wsl, nhập cùng giá trị ở đây rồi Lưu. Để trống khi không bật xác thực. Lưu trong file cài đặt cục bộ; không ghi nhật ký chẩn đoán.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ConfigFileTitle">File cài đặt cục bộ (sao lưu)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ConfigFilePathTooltip">Đường dẫn tuyệt đối tới settings.json trong %LocalAppData%\DockLite\</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ExportSettingsButton">Sao lưu file cài đặt ra…</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ExportSettingsTooltip">Chọn nơi lưu bản sao JSON (cùng định dạng với file cài đặt). Hữu ích trước khi đổi máy hoặc thử cấu hình.</sys:String>

    <sys:String x:Key="Ui_Settings_Wsl_AutoStartLabel">Tự khởi động service trong WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_AutoStartCheck">Khi mở DockLite, nếu chưa có phản hồi thì chạy wsl-docker-service (bash scripts/run-server.sh, không cần chmod +x file .sh)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirLabel">Thư mục wsl-docker-service trong WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirTooltip">Thư mục chứa scripts (run/build): UNC \\wsl.localhost\… nếu mã chỉ nằm trong WSL, hoặc C:\…\wsl-docker-service nếu clone trên ổ đĩa. Để trống: tự tìm cạnh DockLite.App.exe.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroLabel">Distro WSL (tùy chọn)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroTooltip">Ví dụ: Ubuntu. Để trống dùng distro mặc định của wsl.exe.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncTitle">Đồng bộ mã nguồn Go sang WSL (Linux)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncIntro">Sao chép từ ô «Nguồn trong Windows» (hoặc cùng thư mục với ô dịch vụ nếu để trống) sang «Đích trong WSL». Dùng rsync nếu có trong distro; không thì cp -a.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceLabel">Nguồn trong Windows</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceTooltip">Thư mục wsl-docker-service trên ổ Windows (ví dụ C:\...\DockLite\wsl-docker-service). Để trống: dùng cùng đường dẫn với ô «Thư mục wsl-docker-service trong WSL» phía trên (sau khi quy ra wslpath).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestLabel">Đích trong WSL (đường dẫn Unix)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestTooltip">Ví dụ: /home/user/wsl-docker-service — đường tuyệt đối trong Linux (không dùng C:\ hay /mnt/c/...). Điền trước khi Đồng bộ; Lưu để ghi cài đặt.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDeleteExtra">Xóa file ở đích không còn ở nguồn (rsync --delete; chỉ khi rsync có trong WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncVersionEnforce">Chỉ đồng bộ khi version nguồn (file VERSION trên Windows) lớn hơn hoặc bằng version trên đích (WSL); cần file VERSION một dòng (ví dụ 0.1.0) ở thư mục nguồn.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButton">Đồng bộ mã nguồn vào WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButtonTooltip">Chạy rsync hoặc cp trong WSL từ «Nguồn trong Windows» (wslpath) tới «Đích trong WSL». Dùng ô hiện tại (không bắt buộc Lưu trước).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ResourcesTitle">Tài nguyên máy phía WSL (qua API)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ResourcesIntro" xml:space="preserve">Đọc từ distro chạy wsl-docker-service: RAM, load trung bình, đĩa gốc. Cần service đang chạy và địa chỉ base URL đúng (tab Kết nối).</sys:String>
