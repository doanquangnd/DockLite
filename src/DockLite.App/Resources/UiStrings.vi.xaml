    <sys:String x:Key="Ui_Settings_Display_TimeZoneLabel">Múi giờ hiển thị (ứng dụng)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_TimeZoneTooltip">Chọn «Giờ máy» để dùng múi giờ Windows hiện tại.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DateFormatLabel">Định dạng ngày giờ (chuỗi .NET)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DateFormatTooltip">Ví dụ: dd/MM/yyyy HH:mm:ss, G, g. Đổi sau khi Lưu mới áp dụng toàn app.</sys:String>
