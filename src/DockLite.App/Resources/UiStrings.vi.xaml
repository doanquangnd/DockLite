    <sys:String x:Key="Ui_Help_NoPage_Body">Chưa có màn hình được chọn.</sys:String>
    <sys:String x:Key="Ui_Help_Unknown_Body">Không có nội dung trợ giúp cho màn hình này.</sys:String>
