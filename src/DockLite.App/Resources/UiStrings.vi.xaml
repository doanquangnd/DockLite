    <sys:String x:Key="Ui_Settings_Conn_BaseUrlLabel">Địa chỉ base URL service (WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_BaseUrlTooltip">Mặc định http://127.0.0.1:17890/. Nếu Windows không kết nối được dù service đã chạy trong WSL, dùng nút bên phải để điền IP WSL.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApplyWslIp">Điền IP WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutLabel">Timeout HTTP (giây, 30–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutTooltip">Áp dụng cho mọi lệnh gọi REST (compose, prune có thể chạy lâu).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_CheckHint">Kiểm tra kết nối đầy đủ (health + Docker) dùng nút ở hàng dưới cùng.</sys:String>

    <sys:String x:Key="Ui_Settings_Wsl_AutoStartLabel">Tự khởi động service trong WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_AutoStartCheck">Khi mở DockLite, nếu chưa có phản hồi thì chạy wsl-docker-service (bash scripts/run-server.sh, không cần chmod +x file .sh)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirLabel">Thư mục wsl-docker-service trong WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirTooltip">Thư mục chứa scripts (run/build): UNC \\wsl.localhost\… nếu mã chỉ nằm trong WSL, hoặc C:\…\wsl-docker-service nếu clone trên ổ đĩa. Để trống: tự tìm cạnh DockLite.App.exe.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroLabel">Distro WSL (tùy chọn)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroTooltip">Ví dụ: Ubuntu. Để trống dùng distro mặc định của wsl.exe.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncTitle">Đồng bộ mã nguồn Go sang WSL (Linux)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncIntro">Sao chép từ ô «Nguồn trong Windows» (hoặc cùng thư mục với ô dịch vụ nếu để trống) sang «Đích trong WSL». Dùng rsync nếu có trong distro; không thì cp -a.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceLabel">Nguồn trong Windows</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceTooltip">Thư mục wsl-docker-service trên ổ Windows (ví dụ C:\...\DockLite\wsl-docker-service). Để trống: dùng cùng đường dẫn với ô «Thư mục wsl-docker-service trong WSL» phía trên (sau khi quy ra wslpath).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestLabel">Đích trong WSL (đường dẫn Unix)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestTooltip">Ví dụ: /home/user/wsl-docker-service — đường tuyệt đối trong Linux (không dùng C:\ hay /mnt/c/...). Điền trước khi Đồng bộ; Lưu để ghi cài đặt.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDeleteExtra">Xóa file ở đích không còn ở nguồn (rsync --delete; chỉ khi rsync có trong WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncVersionEnforce">Chỉ đồng bộ khi version nguồn (file VERSION trên Windows) lớn hơn hoặc bằng version trên đích (WSL); cần file VERSION một dòng (ví dụ 0.1.0) ở thư mục nguồn.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButton">Đồng bộ mã nguồn vào WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButtonTooltip">Chạy rsync hoặc cp trong WSL từ «Nguồn trong Windows» (wslpath) tới «Đích trong WSL». Dùng ô hiện tại (không bắt buộc Lưu trước).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_UnameTitle">Thử distro (uname -a)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_UnameButton">Chạy uname -a trong distro</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_PathSummaryTitle">Tóm tắt đường dẫn WSL hiệu dụng</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_PathSummaryRefresh">Cập nhật tóm tắt</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagTitle">Kiểm tra nhanh (API + wslpath)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagIntro">Gọi health và Docker info theo ô Địa chỉ base URL (tab Cài đặt chung), rồi thử wslpath cho các ô Thư mục dịch vụ, Nguồn đồng bộ và hiển thị đích Unix; không bắt buộc Lưu trước.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagButton">Chạy kiểm tra nhanh</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagTooltip">Health + Docker + wslpath cho giá trị ô hiện tại (tab WSL và URL ở tab trên).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathTitle">Thử wslpath (Windows → Unix)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathTooltip">Đường dẫn Windows (file hoặc thư mục). Dùng Distro WSL ở trên nếu cần.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathRunButton">Chạy wslpath</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceButtonsNote">Start / Dừng / Restart service và chờ health: dùng nút ở hàng dưới cùng (thời gian chờ lấy theo tab «Chờ và health»).</sys:String>

    <sys:String x:Key="Ui_Settings_Health_Intro">Áp dụng cho lần khởi động tự động (mở app), Start/Restart thủ công và polling /api/health. Nhấn Lưu để ghi vào file cài đặt.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_AutoWaitLabel">Chờ health sau khi tự spawn WSL khi mở app (giây, 10–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_AutoWaitTooltip">Sau khi gửi run-server.sh khi mở app, chờ tối đa bấy nhiêu giây để có /api/health.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ManualWaitLabel">Chờ health khi Start / Restart thủ công (giây, 10–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ManualWaitTooltip">Nút Start / Restart trên header hoặc Cài đặt: chờ health tối đa bấy nhiêu giây.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ProbeLabel">Timeout một lần GET /api/health khi poll (giây, 1–60)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ProbeTooltip">Mỗi lần thử GET /api/health trong vòng chờ dài sẽ hủy sau bấy nhiêu giây để không treo quá lâu.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_PollLabel">Khoảng cách giữa các lần poll health (ms, 100–5000)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_PollTooltip">Trong vòng chờ dài, đợi bấy nhiêu ms giữa hai lần gọi /api/health.</sys:String>

    <sys:String x:Key="Ui_Settings_Footer_Save">Lưu</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_SyncCode">Đồng bộ mã → WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_SyncCodeTooltip">Sao chép từ «Nguồn trong Windows» sang «Đích trong WSL» (tab WSL và service; không bắt buộc Lưu trước).</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_Build">Build service WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_BuildTooltip">Chạy bash scripts/build-server.sh trong thư mục wsl-docker-service (go mod tidy + go build). Output stdout/stderr ghi trong nhật ký ứng dụng.</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_Start">Start service WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_StartTooltip">Áp dụng địa chỉ trong ô cho kết nối, gọi wsl bash -lc scripts/run-server.sh (PATH có go), rồi chờ /api/health theo giá trị tab Chờ và health.</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_Stop">Dừng service WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_StopTooltip">Gọi bash scripts/stop-server.sh trong thư mục wsl-docker-service (pkill tiến trình docklite-wsl).</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_Restart">Restart service WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_RestartTooltip">Gọi bash scripts/restart-server.sh (dừng rồi chạy lại run-server), rồi chờ /api/health theo giá trị tab Chờ và health.</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_TestConnection">Kiểm tra kết nối</sys:String>

