    <sys:String x:Key="Ui_Status_Common_InvalidResponse">Invalid response.</sys:String>
    <sys:String x:Key="Ui_Status_Common_ErrorShort">Error.</sys:String>
    <sys:String x:Key="Ui_Status_Common_ErrorGeneric">error</sys:String>
    <sys:String x:Key="Ui_Status_Common_OperationFailed">Operation failed.</sys:String>
