    <sys:String x:Key="Ui_Settings_Wsl_PathSummaryTitle">Effective WSL path summary</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_PathSummaryRefresh">Refresh summary</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagTitle">Quick check (API + wslpath)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagIntro">Includes a recovery checklist; calls health and Docker info using the base URL (Connection tab), then wslpath for service folder, sync source, and Unix destination; Save not required first.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagButton">Run quick check</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagTooltip">Health + Docker + wslpath for current fields (WSL tab and URL above).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathTitle">Try wslpath (Windows → Unix)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathTooltip">Windows path (file or folder). Use WSL distro above if needed.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathRunButton">Run wslpath</sys:String>
