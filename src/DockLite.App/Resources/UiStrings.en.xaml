    <sys:String x:Key="Ui_Settings_Display_TimeZoneLabel">Display time zone (app)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_TimeZoneTooltip">Choose “Machine time” to use the current Windows time zone.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DateFormatLabel">Date/time format (.NET format string)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DateFormatTooltip">Examples: dd/MM/yyyy HH:mm:ss, G, g. Changes apply app-wide after Save.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_PresetsLabel">Quick presets</sys:String>
    <sys:String x:Key="Ui_Settings_Display_PreviewLabel">Preview</sys:String>
    <sys:String x:Key="Ui_Settings_Display_DatePreviewPrefix">Current UTC → </sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsAlertTitle">Resource alerts (Containers page)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsAlertIntro">When stats realtime is on for a container, if CPU or RAM % (used/limit) exceeds a threshold, a warning appears above the sparklines. Set 0 to disable each threshold.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsCpuWarnLabel">CPU % threshold (0 = off)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsCpuWarnTooltip">Integer 0–100. Compared to CPU % in the stats snapshot.</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsMemWarnLabel">RAM % threshold (0 = off)</sys:String>
    <sys:String x:Key="Ui_Settings_Display_StatsMemWarnTooltip">Integer 0–100. RAM % = used / limit from stats; if limit is 0, RAM alert does not apply.</sys:String>

    <sys:String x:Key="Ui_Settings_Conn_LanSecurityBanner">HTTP to the service is not TLS: on a LAN or when using an IP, traffic may be sniffed. If you set DOCKLITE_API_TOKEN in WSL, enter the same value in the API token field below. See docs/docklite-lan-security.md in the repo, or use the button to open the file when it exists next to your build output.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_LanSecurityOpenDoc">Open LAN security doc…</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_LanSecurityOpenDocTooltip">Opens docklite-lan-security.md with the default app (when the file is found relative to the app folder, e.g. dev build from source).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_BaseUrlLabel">Service base URL (WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_BaseUrlTooltip">Default http://127.0.0.1:17890/. If Windows cannot reach the service even though it runs in WSL, use the button on the right to fill WSL IP.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApplyWslIp">Fill WSL IP</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TlsToggleLabel">TLS (https)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TlsToggleText">Use TLS (switch Base URL to https://, same host and port)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TlsPinnedLabel">Trusted fingerprint (SHA-256)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TlsProbeButton">Connect and save TLS pin</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TlsForgetButton">Forget TLS pin</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutLabel">HTTP timeout (seconds, 30–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutTooltip">Applies to all REST calls (compose and prune may take longer).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_CheckHint">Quick API + WSL check (uname, wslpath) below; or use the bottom-row button for health + Docker only.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckTitle">Environment check (API + WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckIntro">Runs once: recovery checklist, health, Docker Engine, uname in the distro, wslpath for paths you entered (same as the WSL tab — unsaved values still apply).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckButton">Run API + WSL check</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckTooltip">Same as «Quick diagnostics» on the WSL tab; output appears here and there.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenLabel">API token (optional, Bearer)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenTooltip">If docklite-wsl uses DOCKLITE_API_TOKEN in WSL, enter the same value here and Save. Leave empty when auth is off. The secret is stored in Windows Credential Manager (resource DockLite:ServiceApiToken), not in settings.json. Not written to diagnostic logs.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenRotateButton">Rotate token on service</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenRotateTooltip">Calls POST /api/auth/rotate with the current Bearer secret. Updates the in-app store and WSL in-memory until the Go process restarts; set DOCKLITE_API_TOKEN in WSL if you need the new value after a restart.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ConfigFileTitle">Local settings file (backup)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ConfigFilePathTooltip">Absolute path to settings.json under %LocalAppData%\DockLite\</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ExportSettingsButton">Back up settings to file…</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ExportSettingsTooltip">Choose where to save a JSON copy (same format as the settings file). Useful before changing machines or testing config.</sys:String>

    <sys:String x:Key="Ui_Settings_Wsl_AutoStartLabel">Auto-start service in WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_AutoStartCheck">When DockLite starts, if there is no response, run wsl-docker-service (bash scripts/run-server.sh; no chmod +x needed for .sh)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirLabel">wsl-docker-service folder (Windows path)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirTooltip">Folder containing scripts (run/build): UNC \\wsl.localhost\… if code lives only in WSL, or C:\…\wsl-docker-service if cloned on a drive. Empty: auto-detect next to DockLite.App.exe.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroLabel">WSL distro (optional)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroTooltip">Example: Ubuntu. Empty: use wsl.exe default distro.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncTitle">Sync Go source to WSL (Linux)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncIntro">Copy from “Windows source” (or the same folder as service if empty) to “Destination in WSL”. Uses rsync if available in the distro; otherwise cp -a.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceLabel">Windows source</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceTooltip">wsl-docker-service folder on Windows (e.g. C:\...\DockLite\wsl-docker-service). Empty: same path as the service folder above (after wslpath).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestLabel">Destination in WSL (Unix path)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestTooltip">Example: /home/user/wsl-docker-service — absolute Linux path (not C:\ or /mnt/c/...). Fill before Sync; Save writes settings.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDeleteExtra">Delete extra files at destination (rsync --delete; only when rsync is available in WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncVersionEnforce">Sync only when source VERSION (Windows) is &gt;= destination VERSION (WSL); one-line VERSION file (e.g. 0.1.0) required in source</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButton">Sync source to WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButtonTooltip">Run rsync or cp in WSL from Windows source (wslpath) to destination. Uses current fields (Save not required first).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ResourcesTitle">WSL host resources (API)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ResourcesIntro" xml:space="preserve">Read from the distro running wsl-docker-service: RAM, load averages, root filesystem. The service must be running and the base URL must be correct (Connection tab).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ResourcesRefreshButton">Refresh resources</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_Resources_StatusOk">WSL host resources updated.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_Resources_StatusError">Could not read WSL host resources.</sys:String>
