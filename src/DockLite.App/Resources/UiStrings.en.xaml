    <sys:String x:Key="Ui_Settings_Footer_Build">Build WSL service</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_BuildTooltip">Run bash scripts/build-server.sh in wsl-docker-service (go mod tidy + go build). Output goes to app log.</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_Start">Start WSL service</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_StartTooltip">Apply URL from the field, run wsl bash -lc scripts/run-server.sh (go on PATH), then wait for /api/health per Wait &amp; health tab.</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_Stop">Stop WSL service</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_StopTooltip">Run bash scripts/stop-server.sh in wsl-docker-service (pkill docklite-wsl).</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_Restart">Restart WSL service</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_RestartTooltip">Run bash scripts/restart-server.sh (stop then run-server), then wait for /api/health per Wait &amp; health tab.</sys:String>
    <sys:String x:Key="Ui_Settings_Footer_TestConnection">Test connection</sys:String>

