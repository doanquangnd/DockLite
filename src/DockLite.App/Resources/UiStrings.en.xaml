    <sys:String x:Key="Ui_Settings_Conn_BaseUrlTooltip">Default http://127.0.0.1:17890/. If Windows cannot reach the service even though it runs in WSL, use the button on the right to fill WSL IP.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApplyWslIp">Fill WSL IP</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutLabel">HTTP timeout (seconds, 30–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_TimeoutTooltip">Applies to all REST calls (compose and prune may take longer).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_CheckHint">Quick API + WSL check (uname, wslpath) below; or use the bottom-row button for health + Docker only.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckTitle">Environment check (API + WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckIntro">Runs once: health, Docker Engine, uname in the distro, wslpath for paths you entered (same as the WSL tab — unsaved values still apply).</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckButton">Run API + WSL check</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_EnvironmentCheckTooltip">Same as «Quick diagnostics» on the WSL tab; output appears here and there.</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenLabel">API token (optional, Bearer)</sys:String>
    <sys:String x:Key="Ui_Settings_Conn_ApiTokenTooltip">If docklite-wsl uses DOCKLITE_API_TOKEN in WSL, enter the same value here and Save. Leave empty when auth is off. Stored in local settings; not written to diagnostic logs.</sys:String>

    <sys:String x:Key="Ui_Settings_Wsl_AutoStartLabel">Auto-start service in WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_AutoStartCheck">When DockLite starts, if there is no response, run wsl-docker-service (bash scripts/run-server.sh; no chmod +x needed for .sh)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirLabel">wsl-docker-service folder (Windows path)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceDirTooltip">Folder containing scripts (run/build): UNC \\wsl.localhost\… if code lives only in WSL, or C:\…\wsl-docker-service if cloned on a drive. Empty: auto-detect next to DockLite.App.exe.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroLabel">WSL distro (optional)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_DistroTooltip">Example: Ubuntu. Empty: use wsl.exe default distro.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncTitle">Sync Go source to WSL (Linux)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncIntro">Copy from “Windows source” (or the same folder as service if empty) to “Destination in WSL”. Uses rsync if available in the distro; otherwise cp -a.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceLabel">Windows source</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncSourceTooltip">wsl-docker-service folder on Windows (e.g. C:\...\DockLite\wsl-docker-service). Empty: same path as the service folder above (after wslpath).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestLabel">Destination in WSL (Unix path)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDestTooltip">Example: /home/user/wsl-docker-service — absolute Linux path (not C:\ or /mnt/c/...). Fill before Sync; Save writes settings.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncDeleteExtra">Delete extra files at destination (rsync --delete; only when rsync is available in WSL)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncVersionEnforce">Sync only when source VERSION (Windows) is &gt;= destination VERSION (WSL); one-line VERSION file (e.g. 0.1.0) required in source</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButton">Sync source to WSL</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_SyncButtonTooltip">Run rsync or cp in WSL from Windows source (wslpath) to destination. Uses current fields (Save not required first).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_UnameTitle">Test distro (uname -a)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_UnameButton">Run uname -a in distro</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_PathSummaryTitle">Effective WSL path summary</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_PathSummaryRefresh">Refresh summary</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagTitle">Quick check (API + wslpath)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagIntro">Calls health and Docker info using the base URL (Connection tab), then wslpath for service folder, sync source, and Unix destination; Save not required first.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagButton">Run quick check</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_QuickDiagTooltip">Health + Docker + wslpath for current fields (WSL tab and URL above).</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathTitle">Try wslpath (Windows → Unix)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathTooltip">Windows path (file or folder). Use WSL distro above if needed.</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_WslpathRunButton">Run wslpath</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_ServiceButtonsNote">Start / Stop / Restart service and health wait: use the bottom row (timeouts from Wait &amp; health tab).</sys:String>

    <sys:String x:Key="Ui_Settings_Health_Intro">Applies to auto-start (open app), manual Start/Restart, and /api/health polling. Press Save to write settings.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_AutoWaitLabel">Health wait after auto-spawn WSL when opening app (seconds, 10–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_AutoWaitTooltip">After sending run-server.sh on app start, wait at most this many seconds for /api/health.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ManualWaitLabel">Health wait for manual Start / Restart (seconds, 10–600)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ManualWaitTooltip">Header or Settings Start/Restart: wait at most this many seconds for health.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ProbeLabel">Timeout per GET /api/health when polling (seconds, 1–60)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_ProbeTooltip">Each health attempt during a long wait is cancelled after this many seconds to avoid hanging.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_PollLabel">Interval between health polls (ms, 100–5000)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_PollTooltip">During a long wait, wait this many ms between two /api/health calls.</sys:String>
    <sys:String x:Key="Ui_Settings_Health_DiagnosticTelemetryLabel">Local diagnostic log (opt-in)</sys:String>
    <sys:String x:Key="Ui_Settings_Health_DiagnosticTelemetryTooltip">When enabled: writes docklite-diagnostic-*.log next to the app log folder (%LocalAppData%\\DockLite\\logs). Minimal connection/health events only (no secrets, no network upload). Share the file for remote support if needed.</sys:String>

