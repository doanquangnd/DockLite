    <sys:String x:Key="Ui_Settings_Wsl_Resources_LineCpu">CPU (cores visible to process): {0}</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_Resources_LineMemory">RAM: {0} / {1} in use (≈ {2:F1}%)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_Resources_LineLoad">Load average (1 / 5 / 15 min): {0:F2} / {1:F2} / {2:F2}</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_Resources_LineDisk">Root disk ({0}): {1} free / {2} total (≈ {3:F1}% used)</sys:String>
    <sys:String x:Key="Ui_Settings_Wsl_Resources_LineTime">Collected (UTC): {0}</sys:String>
