<Application x:Class="DockLite.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DockLite.App.Converters"
             >
    <Application.Resources>
        <ResourceDictionary xmlns:sys="clr-namespace:System.Windows.Controls;assembly=PresentationFramework">
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DockLite.App;component/Themes/ModernTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <sys:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
