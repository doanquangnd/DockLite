<UserControl x:Class="DockLite.App.Views.AppDebugLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="520"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Nhật ký ứng dụng"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#0F172A"
                   Margin="0,0,0,10" />
        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Foreground="#444">
            File log theo ngày trong thư mục bên dưới (UTF-8); trên màn hình cột thời gian hiển thị theo Cài đặt (múi giờ và định dạng), category và nội dung (tab). Lọc theo category và mức (suy đoán từ chữ trong dòng). Xuất file: có bộ lọc thì ghi phần đang xem; không thì ghi toàn bộ đuôi đã đọc (cũng áp dụng định dạng thời gian).
        </TextBlock>

        <TextBox Grid.Row="2"
                 Text="{Binding LogFolderPath, Mode=OneWay}"
                 IsReadOnly="True"
                 Padding="8"
                 Margin="0,0,0,12"
                 FontFamily="Consolas"
                 FontSize="12" />

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <WrapPanel Grid.Row="0"
                       Margin="0,0,0,10">
                <Button Content="Làm mới"
                        Margin="0,0,8,4"
                        Padding="12,6"
                        MinWidth="100"
                        Command="{Binding RefreshCommand}" />
                <Button Content="Mở thư mục log"
                        Margin="0,0,8,4"
                        Padding="12,6"
                        MinWidth="100"
                        Command="{Binding OpenLogFolderCommand}" />
                <Button Content="Sao chép chẩn đoán"
                        Margin="0,0,8,4"
                        Padding="12,6"
                        MinWidth="120"
                        Command="{Binding CopyDiagnosticsCommand}" />
                <Button Content="Xuất log ra file"
                        Margin="0,0,8,4"
                        Padding="12,6"
                        MinWidth="120"
                        Command="{Binding ExportLogCommand}" />
            </WrapPanel>
            <TextBlock Grid.Row="1"
                       Text="{Binding StatusMessage}"
                       Foreground="#2E7D32"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <Grid Grid.Row="2"
                  Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Category:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <Border Grid.Column="1"
                            Margin="0,0,16,0"
                            MinWidth="160"
                            Style="{StaticResource InputChromeBorderStyle}">
                        <ComboBox BorderThickness="0"
                                  Background="Transparent"
                                  Padding="8,6"
                                  MinHeight="34"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding CategoryOptions}"
                                  SelectedItem="{Binding SelectedCategory}" />
                    </Border>
                    <TextBlock Grid.Column="2"
                               Text="Mức:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <Border Grid.Column="3"
                            MinWidth="140"
                            Style="{StaticResource InputChromeBorderStyle}">
                        <ComboBox BorderThickness="0"
                                  Background="Transparent"
                                  Padding="8,6"
                                  MinHeight="34"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding LevelOptions}"
                                  SelectedItem="{Binding SelectedLevelOption}" />
                    </Border>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Lọc chuỗi:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4"
                             ToolTip="Chỉ hiện các dòng chứa chuỗi này (không phân biệt hoa thường). Để trống để không lọc theo chuỗi." />
                </Grid>
            </Grid>
            <!-- MaxHeight: cuộn nội dung trong khung; vùng MainWindow vẫn cuộn riêng -->
            <Grid Grid.Row="3"
                  MinHeight="220"
                  MaxHeight="520">
                <ListBox VerticalAlignment="Stretch"
                         ItemsSource="{Binding VisibleLines}"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"
                         Background="{StaticResource CardBackgroundBrush}"
                         BorderBrush="{StaticResource CardBorderBrush}"
                         BorderThickness="1"
                         Padding="6"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2,1" />
                        </Style>
                    </ListBox.Resources>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
