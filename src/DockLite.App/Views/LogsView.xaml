<UserControl x:Class="DockLite.App.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:DockLite.App.Converters"
             xmlns:models="clr-namespace:DockLite.App.Models"
             xmlns:behaviors="clr-namespace:DockLite.App.Behaviors"
             d:DesignHeight="520"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Log container"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemePageTitleBrush}"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1"
              Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Container:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                       Margin="0,0,8,6" />
            <ComboBox Grid.Row="0"
                      Grid.Column="1"
                      Margin="0,0,12,6"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding ContainerOptions}"
                      SelectedItem="{Binding SelectedContainer}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ShortId}"
                                       Foreground="{DynamicResource ThemeMutedForegroundBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Text="Tail:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                       Margin="0,0,8,6" />
            <TextBox Grid.Row="0"
                     Grid.Column="3"
                     Text="{Binding TailLines}"
                     Margin="0,0,0,6" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Tìm:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                       Margin="0,0,8,0" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Grid.ColumnSpan="3"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     ToolTip="Lọc dòng chứa chuỗi. Với dòng rất dài (&gt;65536 ký tự) chỉ khớp trong phần đầu dòng." />
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                   FontSize="12"
                   Text="{DynamicResource Ui_Logs_EmptyContainerOptionsHint}"
                   Visibility="{Binding ShowEmptyContainerOptionsHint, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- MaxHeight: cuộn nội dung log trong khung; ScrollViewer MainWindow vẫn cuộn cả trang -->
        <Grid Grid.Row="3"
              MinHeight="240"
              MaxHeight="520">
            <ListBox VerticalAlignment="Stretch"
                     behaviors:MouseWheelScrollBubbling.BubbleToMainContentScroll="True"
                     ItemsSource="{Binding Lines}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="12"
                     Background="{DynamicResource CardBackgroundBrush}"
                     BorderBrush="{DynamicResource CardBorderBrush}"
                     BorderThickness="1">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel VirtualizingPanel.CacheLengthUnit="Page"
                                                VirtualizingPanel.CacheLength="1,1"
                                                VirtualizingPanel.ScrollUnit="Pixel" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:LogLineViewModel}">
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="NoWrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeLogSeverityDefaultBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:LogSeverity.Error}">
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeLogSeverityErrorBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:LogSeverity.Warn}">
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeLogSeverityWarnBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:LogSeverity.Info}">
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeLogSeverityInfoBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:LogSeverity.Debug}">
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeLogSeverityDebugBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <WrapPanel Grid.Row="4"
                   Margin="0,10,0,0">
            <Button Content="Tải container"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="100"
                    Command="{Binding LoadContainersCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Tải tail"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding LoadTailCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Theo dõi (WS)"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="110"
                    Command="{Binding ToggleFollowCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Xóa màn hình"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="100"
                    Command="{Binding ClearLogCommand}" />
        </WrapPanel>

        <Border Grid.Row="5"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                Padding="12"
                Margin="0,12,0,0"
                CornerRadius="10">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeBodyTextBrush}" />
        </Border>
    </Grid>
</UserControl>
