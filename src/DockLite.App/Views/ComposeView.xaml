<UserControl x:Class="DockLite.App.Views.ComposeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:DockLite.App.Converters"
             d:DesignHeight="560"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="220" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Docker Compose"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemePageTitleBrush}"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1"
                    Margin="0,0,0,10">
            <TextBlock Text="Thêm thư mục project (Windows: C:\... hoặc WSL: /mnt/c/...)"
                       Margin="0,0,0,4"
                       Foreground="{DynamicResource ThemeBodyTextBrush}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NewProjectPath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Content="Chọn thư mục"
                        Padding="12,6"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Command="{Binding BrowseProjectFolderCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                <Button Grid.Column="2"
                        Content="Thêm"
                        Padding="12,6"
                        MinWidth="80"
                        Command="{Binding AddProjectCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            </Grid>
            <TextBlock Margin="0,10,0,4"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                       FontSize="12"
                       Text="File compose tùy chọn (mỗi dòng một đường dẫn tương đối trong thư mục project, ví dụ docker-compose.yml rồi compose.override.yml). Để trống: Docker tự tìm compose mặc định." />
            <TextBox MinHeight="56"
                     MaxHeight="120"
                     Padding="8"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding NewProjectComposeFilesText, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,0,0,8"
                Style="{StaticResource RoundedTableChromeStyle}">
            <DataGrid ItemsSource="{Binding Projects}"
                      SelectedItem="{Binding SelectedProject}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên"
                                        Binding="{Binding Name}"
                                        Width="120" />
                    <DataGridTextColumn Header="Đường dẫn WSL"
                                        Binding="{Binding WslPath}"
                                        Width="*" />
                    <DataGridTextColumn Header="Id"
                                        Binding="{Binding Id}"
                                        Width="120" />
                    <DataGridTextColumn Header="File -f"
                                        Binding="{Binding ComposeFilesSummary}"
                                        Width="200" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,0,0,8"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                Padding="14"
                CornerRadius="12">
            <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeBodyTextBrush}"
                           Text="File compose cho project đang chọn (-f)" />
                <TextBlock Margin="0,4,0,8"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                           FontSize="12"
                           Text="Mỗi dòng một file tương đối trong thư mục project. Để trống và Lưu: dùng lại compose mặc định trong thư mục." />
                <TextBox MinHeight="72"
                         MaxHeight="160"
                         Padding="8"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding ComposeFilesEditorText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Margin="0,10,0,0"
                        Padding="12,6"
                        HorizontalAlignment="Left"
                        MinWidth="160"
                        Content="Lưu file compose (-f)"
                        Command="{Binding SaveComposeFilesCommand}"
                        IsEnabled="{Binding CanSaveComposeFiles}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Margin="0,8,0,0"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                Padding="14"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Service (theo compose file)"
                               Margin="0,0,0,6" />
                    <ListBox MinHeight="140"
                             MaxHeight="200"
                             ItemsSource="{Binding Services}"
                             SelectedItem="{Binding SelectedService}" />
                </DockPanel>
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Top">
                    <Button Content="Tải danh sách service"
                            Margin="0,0,0,8"
                            Padding="12,6"
                            HorizontalAlignment="Left"
                            Command="{Binding LoadComposeServicesCommand}"
                            IsEnabled="{Binding CanLoadComposeServices}" />
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="Start service"
                                Margin="0,0,8,4"
                                Padding="12,6"
                                Command="{Binding ComposeServiceStartCommand}"
                                IsEnabled="{Binding CanComposeServiceAction}" />
                        <Button Content="Stop service"
                                Margin="0,0,8,4"
                                Padding="12,6"
                                Command="{Binding ComposeServiceStopCommand}"
                                IsEnabled="{Binding CanComposeServiceAction}" />
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Logs service"
                                Padding="12,6"
                                VerticalAlignment="Bottom"
                                Command="{Binding ComposeServiceLogsCommand}"
                                IsEnabled="{Binding CanComposeServiceAction}" />
                        <TextBlock Text="tail:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeBodyTextBrush}"
                                   Margin="12,0,8,0" />
                        <TextBox MinWidth="56"
                                 Padding="6,4"
                                 Text="{Binding ComposeServiceLogsTail, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <TextBlock Margin="0,10,0,4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Exec không TTY (docker compose exec -T)" />
                    <TextBlock Margin="0,0,0,4"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                               FontSize="11"
                               Text="Nhập lệnh: các từ cách nhau bằng khoảng trắng (ví dụ: uname -a). Shell tương tác (-it) cần terminal bên ngoài." />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <TextBox MinWidth="220"
                                 Padding="6,4"
                                 Margin="0,0,8,0"
                                 Text="{Binding ComposeExecCommandLine, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Chạy exec"
                                Padding="12,6"
                                VerticalAlignment="Center"
                                Command="{Binding ComposeServiceExecCommand}"
                                IsEnabled="{Binding CanComposeServiceAction}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Margin="0,8,0,8"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                Padding="14"
                CornerRadius="12">
            <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeBodyTextBrush}"
                           Text="Terminal WSL (gợi ý lệnh)" />
                <TextBlock Margin="0,4,0,8"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeBodyTextBrush}"
                           FontSize="12"
                           Text="Chọn project và service ở trên, rồi dán lệnh dưới vào terminal Windows (PowerShell hoặc cmd). Chạy trong đúng distro có Docker và project." />
                <TextBox MinHeight="56"
                         Padding="8"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding SuggestedWslTerminalComposeExecLine, Mode=OneWay}" />
                <Button Margin="0,10,0,0"
                        Padding="12,6"
                        HorizontalAlignment="Left"
                        MinWidth="200"
                        Content="Sao chép lệnh terminal"
                        Command="{Binding CopySuggestedTerminalComposeLineCommand}"
                        IsEnabled="{Binding CanCopySuggestedTerminalComposeLine}" />
                <Button Margin="0,8,0,0"
                        Padding="12,6"
                        HorizontalAlignment="Left"
                        MinWidth="280"
                        Content="Mở terminal WSL trong thư mục project"
                        Command="{Binding OpenTerminalInProjectFolderCommand}"
                        IsEnabled="{Binding CanOpenTerminalInProjectFolder}" />
            </StackPanel>
        </Border>

        <WrapPanel Grid.Row="6"
                   Margin="0,10,0,8">
            <Button Content="Làm mới danh sách"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding LoadProjectsCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Xóa khỏi danh sách"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding RemoveProjectCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="compose up -d"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding ComposeUpCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="compose down"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding ComposeDownCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="compose ps"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding ComposePsCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
        </WrapPanel>

        <DockPanel Grid.Row="7"
                   MinHeight="200"
                   Margin="0,8,0,12"
                   LastChildFill="True">
            <TextBlock DockPanel.Dock="Top"
                       Text="Output lệnh"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Padding="12"
                    CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding CommandOutput}"
                               TextWrapping="Wrap"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="12"
                               Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}" />
                </ScrollViewer>
            </Border>
        </DockPanel>

        <Border Grid.Row="8"
                BorderBrush="{DynamicResource ThemeSeparatorBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeBodyTextBrush}" />
        </Border>
    </Grid>
</UserControl>
