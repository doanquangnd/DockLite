<UserControl x:Class="DockLite.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="640"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <Grid Margin="4,0,8,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="380" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Ui_Settings_PageTitle}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemePageTitleBrush}"
                   Margin="0,0,0,16" />

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="1">
            <TabControl Style="{StaticResource SettingsTabControlStyle}"
                        ItemContainerStyle="{StaticResource SettingsTabItemStyle}"
                        Padding="10,10,10,0">
            <TabItem Header="{DynamicResource Ui_Settings_Tab_Connection}">
                <StackPanel Margin="24,22,26,26"
                            TextElement.Foreground="{DynamicResource ThemeControlForegroundBrush}">
                        <TextBlock Text="{DynamicResource Ui_Settings_Conn_BaseUrlLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ServiceBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                     Margin="0,0,8,0"
                                     ToolTip="{DynamicResource Ui_Settings_Conn_BaseUrlTooltip}" />
                            <Button Grid.Column="1"
                                    Padding="12,6"
                                    MinWidth="120"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Ui_Settings_Conn_ApplyWslIp}"
                                    Command="{Binding ApplyWslIpCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                        </Grid>
                        <TextBlock Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeWarningForegroundBrush}"
                                   FontSize="12"
                                   Text="{Binding ServiceBaseUrlSecurityHint}" />
                        <TextBlock Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   FontSize="12"
                                   Text="{Binding ServiceBaseUrlPortHint}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Conn_TimeoutLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding HttpTimeoutSecondsText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,8"
                                 ToolTip="{DynamicResource Ui_Settings_Conn_TimeoutTooltip}" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   FontSize="12"
                                   Text="{DynamicResource Ui_Settings_Conn_CheckHint}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Settings_Tab_Wsl}">
                <StackPanel Margin="24,22,26,26"
                            TextElement.Foreground="{DynamicResource ThemeControlForegroundBrush}">
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_AutoStartLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <CheckBox IsChecked="{Binding AutoStartWslService, Mode=TwoWay}"
                                  Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource Ui_Settings_Wsl_AutoStartCheck}"
                                       TextWrapping="Wrap" />
                        </CheckBox>
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_ServiceDirLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding WslDockerServiceWindowsPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,8"
                                 ToolTip="{DynamicResource Ui_Settings_Wsl_ServiceDirTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_DistroLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding WslDistribution, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,12"
                                 ToolTip="{DynamicResource Ui_Settings_Wsl_DistroTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_SyncTitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,6" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,8"
                                   Text="{DynamicResource Ui_Settings_Wsl_SyncIntro}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_SyncSourceLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding WslDockerServiceSyncSourceWindowsPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,8"
                                 ToolTip="{DynamicResource Ui_Settings_Wsl_SyncSourceTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_SyncDestLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding WslDockerServiceLinuxSyncPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,8"
                                 FontFamily="Consolas"
                                 ToolTip="{DynamicResource Ui_Settings_Wsl_SyncDestTooltip}" />
                        <CheckBox IsChecked="{Binding WslDockerServiceSyncDeleteExtra, Mode=TwoWay}"
                                  Margin="0,0,0,10">
                            <TextBlock TextWrapping="Wrap"
                                       Text="{DynamicResource Ui_Settings_Wsl_SyncDeleteExtra}" />
                        </CheckBox>
                        <CheckBox IsChecked="{Binding WslDockerServiceSyncEnforceVersionGe, Mode=TwoWay}"
                                  Margin="0,0,0,10">
                            <TextBlock TextWrapping="Wrap"
                                       Text="{DynamicResource Ui_Settings_Wsl_SyncVersionEnforce}" />
                        </CheckBox>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <Button Content="{DynamicResource Ui_Settings_Wsl_SyncButton}"
                                    Padding="12,6"
                                    MinWidth="220"
                                    Command="{Binding SyncServiceSourceToWslCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                                    ToolTip="{DynamicResource Ui_Settings_Wsl_SyncButtonTooltip}" />
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_UnameTitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,6" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Button Content="{DynamicResource Ui_Settings_Wsl_UnameButton}"
                                    Padding="12,6"
                                    MinWidth="200"
                                    VerticalAlignment="Top"
                                    Command="{Binding TestDistroCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DistroTestResult}"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_PathSummaryTitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <Button Content="{DynamicResource Ui_Settings_Wsl_PathSummaryRefresh}"
                                Padding="12,6"
                                HorizontalAlignment="Left"
                                MinWidth="160"
                                Margin="0,0,0,8"
                                Command="{Binding RefreshEffectiveWslPathSummaryCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                        <TextBlock Text="{Binding EffectiveWslPathSummary}"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_QuickDiagTitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,6" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,8"
                                   Text="{DynamicResource Ui_Settings_Wsl_QuickDiagIntro}" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Button Content="{DynamicResource Ui_Settings_Wsl_QuickDiagButton}"
                                    Padding="12,6"
                                    MinWidth="200"
                                    VerticalAlignment="Top"
                                    Command="{Binding QuickWslDiagnosticsCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                                    ToolTip="{DynamicResource Ui_Settings_Wsl_QuickDiagTooltip}" />
                        </StackPanel>
                        <TextBox Text="{Binding WslQuickDiagnosticsText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="120"
                                 MaxHeight="280"
                                 Padding="8"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}"
                                 Margin="0,0,0,12" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Wsl_WslpathTitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,6" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding WslpathProbeWindowsPath, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                     Margin="0,0,8,0"
                                     ToolTip="{DynamicResource Ui_Settings_Wsl_WslpathTooltip}" />
                            <Button Grid.Column="1"
                                    Padding="12,6"
                                    MinWidth="120"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Ui_Settings_Wsl_WslpathRunButton}"
                                    Command="{Binding ProbeWslpathCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                        </Grid>
                        <TextBlock Text="{Binding WslpathProbeResult}"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   FontSize="12"
                                   Text="{DynamicResource Ui_Settings_Wsl_ServiceButtonsNote}" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Settings_Tab_Display}">
                <StackPanel Margin="24,22,26,26"
                            TextElement.Foreground="{DynamicResource ThemeControlForegroundBrush}">
                        <TextBlock Text="{DynamicResource Ui_Settings_Display_LanguageLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding UiLanguageList}"
                                  DisplayMemberPath="Title"
                                  SelectedItem="{Binding SelectedUiLanguageItem}"
                                  Padding="8,6"
                                  Margin="0,0,0,12"
                                  MinHeight="36"
                                  ToolTip="{DynamicResource Ui_Settings_Display_LanguageTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Display_ThemeLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding UiThemeList}"
                                  DisplayMemberPath="Title"
                                  SelectedItem="{Binding SelectedUiThemeItem}"
                                  Padding="8,6"
                                  Margin="0,0,0,12"
                                  MinHeight="36"
                                  ToolTip="{DynamicResource Ui_Settings_Display_ThemeTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Display_TimeZoneLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding TimeZoneOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedUiTimeZoneId, UpdateSourceTrigger=PropertyChanged}"
                                  Padding="8,6"
                                  Margin="0,0,0,12"
                                  MinHeight="36"
                                  ToolTip="{DynamicResource Ui_Settings_Display_TimeZoneTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Display_DateFormatLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding UiDateTimeFormat, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,8"
                                 FontFamily="Consolas"
                                 ToolTip="{DynamicResource Ui_Settings_Display_DateFormatTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Display_PresetsLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding DateFormatPresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Margin="0,0,6,6"
                                            Padding="10,4"
                                            FontSize="12"
                                            Command="{Binding DataContext.ApplyDateFormatPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{DynamicResource Ui_Settings_Display_PreviewLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,6" />
                        <TextBlock Text="{Binding DateFormatPreviewText}"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}"
                                   Margin="0,0,0,8" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{DynamicResource Ui_Settings_Tab_HealthWait}">
                <StackPanel Margin="24,22,26,26"
                            TextElement.Foreground="{DynamicResource ThemeControlForegroundBrush}">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,12"
                                   Text="{DynamicResource Ui_Settings_Health_Intro}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Health_AutoWaitLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding WslAutoStartHealthWaitSecondsText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,12"
                                 ToolTip="{DynamicResource Ui_Settings_Health_AutoWaitTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Health_ManualWaitLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding WslManualHealthWaitSecondsText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,12"
                                 ToolTip="{DynamicResource Ui_Settings_Health_ManualWaitTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Health_ProbeLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding HealthProbeSingleRequestSecondsText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,12"
                                 ToolTip="{DynamicResource Ui_Settings_Health_ProbeTooltip}" />
                        <TextBlock Text="{DynamicResource Ui_Settings_Health_PollLabel}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding WslHealthPollIntervalMillisecondsText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 Margin="0,0,0,8"
                                 ToolTip="{DynamicResource Ui_Settings_Health_PollTooltip}" />
                </StackPanel>
            </TabItem>
            </TabControl>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,4,0,14"
                    HorizontalAlignment="Stretch">
            <Button Content="{DynamicResource Ui_Settings_Footer_Save}"
                    Padding="16,6"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="{DynamicResource Ui_Settings_Footer_SyncCode}"
                    Padding="16,6"
                    MinWidth="168"
                    Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding SyncServiceSourceToWslCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                    ToolTip="{DynamicResource Ui_Settings_Footer_SyncCodeTooltip}" />
            <Button Content="{DynamicResource Ui_Settings_Footer_Build}"
                    Padding="16,6"
                    MinWidth="158"
                    Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding BuildWslServiceManualCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                    ToolTip="{DynamicResource Ui_Settings_Footer_BuildTooltip}" />
            <Button Content="{DynamicResource Ui_Settings_Footer_Start}"
                    Padding="16,6"
                    MinWidth="168"
                    Margin="0,0,8,0"
                    Command="{Binding StartWslServiceManualCommand}"
                    IsEnabled="{Binding CanStartWslServiceButton}"
                    ToolTip="{DynamicResource Ui_Settings_Footer_StartTooltip}" />
            <Button Content="{DynamicResource Ui_Settings_Footer_Stop}"
                    Padding="16,6"
                    MinWidth="152"
                    Margin="0,0,8,0"
                    Command="{Binding StopWslServiceManualCommand}"
                    IsEnabled="{Binding CanStopWslServiceButton}"
                    ToolTip="{DynamicResource Ui_Settings_Footer_StopTooltip}" />
            <Button Content="{DynamicResource Ui_Settings_Footer_Restart}"
                    Padding="16,6"
                    MinWidth="168"
                    Margin="0,0,8,0"
                    Command="{Binding RestartWslServiceManualCommand}"
                    IsEnabled="{Binding CanRestartWslServiceButton}"
                    ToolTip="{DynamicResource Ui_Settings_Footer_RestartTooltip}" />
            <Button Content="{DynamicResource Ui_Settings_Footer_TestConnection}"
                    Padding="16,6"
                    MinWidth="140"
                    Command="{Binding TestConnectionCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
        </StackPanel>

        <Border Grid.Row="3"
                Margin="4,0,8,0"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                Padding="16"
                CornerRadius="10"
                VerticalAlignment="Top">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeBodyTextBrush}" />
        </Border>
    </Grid>
</UserControl>
