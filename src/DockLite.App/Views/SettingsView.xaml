<UserControl x:Class="DockLite.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="520"
             d:DesignWidth="640"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Cài đặt"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <TextBlock Grid.Row="1"
                   Text="Địa chỉ base URL service (WSL)"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding ServiceBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8"
                     Margin="0,0,8,0"
                     ToolTip="Mặc định http://127.0.0.1:17890/. Nếu Windows không kết nối được dù service đã chạy trong WSL, dùng nút bên phải để điền IP WSL." />
            <Button Grid.Column="1"
                    Padding="12,6"
                    MinWidth="120"
                    VerticalAlignment="Center"
                    Content="Điền IP WSL"
                    Command="{Binding ApplyWslIpCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="Timeout HTTP (giây, 30–600)"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />
        <TextBox Grid.Row="4"
                 Text="{Binding HttpTimeoutSecondsText, UpdateSourceTrigger=PropertyChanged}"
                 Padding="8"
                 Margin="0,0,0,12"
                 ToolTip="Áp dụng cho mọi lệnh gọi REST (compose, prune có thể chạy lâu)." />

        <TextBlock Grid.Row="5"
                   Text="Tự khởi động service trong WSL"
                   FontWeight="SemiBold"
                   Margin="0,8,0,6" />
        <CheckBox Grid.Row="6"
                  IsChecked="{Binding AutoStartWslService, Mode=TwoWay}"
                  Margin="0,0,0,8">
            <TextBlock Text="Khi mở DockLite, nếu chưa có phản hồi thì chạy wsl-docker-service (bash scripts/run-server.sh, không cần chmod +x file .sh)"
                       TextWrapping="Wrap" />
        </CheckBox>

        <TextBlock Grid.Row="7"
                   Text="Thư mục wsl-docker-service (Windows, tùy chọn)"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />
        <TextBox Grid.Row="8"
                 Text="{Binding WslDockerServiceWindowsPath, UpdateSourceTrigger=PropertyChanged}"
                 Padding="8"
                 Margin="0,0,0,8"
                 ToolTip="Để trống: tự tìm thư mục wsl-docker-service cùng cây thư mục với DockLite.App.exe." />

        <TextBlock Grid.Row="9"
                   Text="Distro WSL (tùy chọn)"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />
        <TextBox Grid.Row="10"
                 Text="{Binding WslDistribution, UpdateSourceTrigger=PropertyChanged}"
                 Padding="8"
                 Margin="0,0,0,12"
                 ToolTip="Ví dụ: Ubuntu. Để trống dùng distro mặc định của wsl.exe." />

        <StackPanel Grid.Row="11"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Lưu"
                    Padding="16,6"
                    MinWidth="100"
                    Margin="0,0,8,0"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Khởi động service WSL"
                    Padding="16,6"
                    MinWidth="168"
                    Margin="0,0,8,0"
                    Command="{Binding StartWslServiceManualCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                    ToolTip="Áp dụng địa chỉ trong ô cho kết nối, gọi wsl bash -lc scripts/run-server.sh (PATH có go), rồi chờ /api/health tối đa khoảng 90 giây." />
            <Button Content="Kiểm tra kết nối"
                    Padding="16,6"
                    MinWidth="140"
                    Command="{Binding TestConnectionCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
        </StackPanel>

        <Border Grid.Row="12"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="12"
                CornerRadius="4"
                VerticalAlignment="Top">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
