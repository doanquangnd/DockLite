<UserControl x:Class="DockLite.App.Views.ContainersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="480"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Container"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Lọc:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding FilterKinds}"
                      SelectedItem="{Binding FilterKind}" />
            <TextBlock Grid.Column="3"
                       Text="Tìm:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox Grid.Column="4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" />
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedContainer}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#FAFAFA">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding ShortId}"
                                    Width="90" />
                <DataGridTextColumn Header="Tên"
                                    Binding="{Binding Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Image"
                                    Binding="{Binding Image}"
                                    Width="160" />
                <DataGridTextColumn Header="Trạng thái"
                                    Binding="{Binding Status}"
                                    Width="200" />
                <DataGridTextColumn Header="Cổng"
                                    Binding="{Binding Ports}"
                                    Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="3"
                   Margin="0,10,0,8">
            <Button Content="Làm mới"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="100"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Start"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding StartSelectedCommand}"
                    IsEnabled="{Binding CanStart}" />
            <Button Content="Stop"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding StopSelectedCommand}"
                    IsEnabled="{Binding CanStop}" />
            <Button Content="Restart"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding RestartSelectedCommand}"
                    IsEnabled="{Binding CanRestart}" />
            <Button Content="Xóa"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding RemoveSelectedCommand}"
                    IsEnabled="{Binding CanRemove}" />
        </WrapPanel>

        <Border Grid.Row="4"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
