<UserControl x:Class="DockLite.App.Views.ContainersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="480"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Container"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Lọc:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding FilterKinds}"
                      SelectedItem="{Binding FilterKind}" />
            <TextBlock Grid.Column="3"
                       Text="Tìm:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox Grid.Column="4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" />
        </Grid>

        <Border Grid.Row="2"
                Margin="0,0,0,8"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="10"
                CornerRadius="4">
            <StackPanel>
                <WrapPanel Margin="0,0,0,8">
                    <Button Content="Top 5 RAM (snapshot)"
                            Padding="12,6"
                            MinWidth="160"
                            Margin="0,0,8,4"
                            Command="{Binding RefreshTopMemoryCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                    <Button Content="Top 5 CPU (snapshot)"
                            Padding="12,6"
                            MinWidth="160"
                            Margin="0,0,8,4"
                            Command="{Binding RefreshTopCpuCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                </WrapPanel>
                <TextBlock Margin="0,0,0,4"
                           FontWeight="SemiBold"
                           Text="Theo RAM" />
                <TextBlock Text="{Binding TopMemorySummaryText}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="#333" />
                <TextBlock Margin="0,12,0,4"
                           FontWeight="SemiBold"
                           Text="Theo CPU %" />
                <TextBlock Text="{Binding TopCpuSummaryText}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="#333" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedContainerRow}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#FAFAFA">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="48"
                                        Header="Chọn">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="90"
                                    Binding="{Binding Model.ShortId}"
                                    Header="ID"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Model.Name}"
                                    Header="Tên"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="160"
                                    Binding="{Binding Model.Image}"
                                    Header="Image"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="200"
                                    Binding="{Binding Model.Status}"
                                    Header="Trạng thái"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="120"
                                    Binding="{Binding Model.Ports}"
                                    Header="Cổng"
                                    IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <Expander Grid.Row="4"
                  Margin="0,8,0,0"
                  Header="Chi tiết container (inspect + stats)">
            <ScrollViewer MaxHeight="420"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8,0,0">
                    <StackPanel Margin="0,0,0,8"
                                Orientation="Horizontal">
                        <CheckBox VerticalAlignment="Center"
                                  Content="Stats realtime (polling API)"
                                  IsChecked="{Binding IsStatsRealtimeEnabled}" />
                        <TextBlock Margin="16,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="Chu kỳ (giây):" />
                        <ComboBox MinWidth="72"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding StatsRealtimeIntervalChoices}"
                                  SelectedItem="{Binding StatsRealtimeIntervalSeconds}" />
                    </StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="Stats" />
                    <TextBox MinHeight="72"
                             Margin="0,4,0,0"
                             Padding="8"
                             FontFamily="Segoe UI"
                             IsReadOnly="True"
                             Text="{Binding DetailStatsText}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Text="Inspect (JSON)" />
                    <TextBox MinHeight="140"
                             Margin="0,4,0,0"
                             Padding="8"
                             FontFamily="Consolas"
                             IsReadOnly="True"
                             Text="{Binding DetailInspectJson}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </ScrollViewer>
        </Expander>

        <WrapPanel Grid.Row="5"
                   Margin="0,10,0,8">
            <Button Content="Làm mới"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="100"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Chọn tất cả"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding SelectAllFilteredCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Bỏ chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding ClearRowSelectionChecksCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Start đã chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding BatchStartCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Stop đã chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding BatchStopCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Xóa đã chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding BatchRemoveCheckedCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Tải chi tiết"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="110"
                    Command="{Binding LoadDetailCommand}"
                    IsEnabled="{Binding CanLoadDetail}" />
            <Button Content="Start"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding StartSelectedCommand}"
                    IsEnabled="{Binding CanStart}" />
            <Button Content="Stop"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding StopSelectedCommand}"
                    IsEnabled="{Binding CanStop}" />
            <Button Content="Restart"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding RestartSelectedCommand}"
                    IsEnabled="{Binding CanRestart}" />
            <Button Content="Xóa"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding RemoveSelectedCommand}"
                    IsEnabled="{Binding CanRemove}" />
        </WrapPanel>

        <Border Grid.Row="6"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
