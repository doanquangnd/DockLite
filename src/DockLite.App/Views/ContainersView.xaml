<UserControl x:Class="DockLite.App.Views.ContainersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:DockLite.App.Behaviors"
             d:DesignHeight="480"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Container"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemePageTitleBrush}"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Lọc:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                       Margin="0,0,8,0" />
            <ComboBox Grid.Column="1"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding FilterKinds}"
                      SelectedItem="{Binding FilterKind}" />
            <TextBlock Grid.Column="3"
                       Text="Tìm:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                       Margin="0,0,8,0" />
            <TextBox Grid.Column="4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     ToolTip="Tìm trên tên, image, ID, trạng thái, cổng, lệnh, nhãn (khóa hoặc giá trị)" />
        </Grid>

        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                Padding="14"
                CornerRadius="10">
            <StackPanel>
                <WrapPanel Margin="0,0,0,8">
                    <Button Content="Top 5 RAM (snapshot)"
                            Padding="12,6"
                            MinWidth="160"
                            Margin="0,0,8,4"
                            Command="{Binding RefreshTopMemoryCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                    <Button Content="Top 5 CPU (snapshot)"
                            Padding="12,6"
                            MinWidth="160"
                            Margin="0,0,8,4"
                            Command="{Binding RefreshTopCpuCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
                </WrapPanel>
                <TextBlock Margin="0,0,0,4"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeBodyTextBrush}"
                           Text="Theo RAM" />
                <TextBlock Text="{Binding TopMemorySummaryText}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}" />
                <TextBlock Margin="0,12,0,4"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeBodyTextBrush}"
                           Text="Theo CPU %" />
                <TextBlock Text="{Binding TopCpuSummaryText}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                MinHeight="300"
                Margin="0,0,0,8"
                behaviors:MouseWheelScrollBubbling.BubbleToMainContentScroll="True"
                Style="{StaticResource RoundedTableChromeStyle}">
            <DataGrid ItemsSource="{Binding FilteredItems}"
                      SelectedItem="{Binding SelectedContainerRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="48"
                                            Header="Chọn">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="90"
                                        Binding="{Binding Model.ShortId}"
                                        Header="ID"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Width="*"
                                        Binding="{Binding Model.Name}"
                                        Header="Tên"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Width="160"
                                        Binding="{Binding Model.Image}"
                                        Header="Image"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Width="200"
                                        Binding="{Binding Model.Status}"
                                        Header="Trạng thái"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Width="120"
                                        Binding="{Binding Model.Ports}"
                                        Header="Cổng"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Width="220"
                                        MinWidth="120"
                                        Binding="{Binding Model.LabelsSummary}"
                                        Header="Nhãn"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Expander Grid.Row="4"
                  Margin="0,8,0,0"
                  Foreground="{DynamicResource ThemeBodyTextBrush}"
                  Header="Chi tiết container (inspect + stats)">
            <ScrollViewer MaxHeight="720"
                          behaviors:MouseWheelScrollBubbling.BubbleToMainContentScroll="True"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8,0,0">
                    <StackPanel Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox VerticalAlignment="Center"
                                      Content="Stats realtime"
                                      IsChecked="{Binding IsStatsRealtimeEnabled}" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                       FontSize="12"
                                       Text="{Binding StatsRealtimePollCount, StringFormat='Mẫu stats: {0}'}" />
                        </StackPanel>
                        <CheckBox Margin="0,6,0,0"
                                  Content="Dùng WebSocket stream (thay polling REST)"
                                  IsChecked="{Binding UseStatsWebSocket}"
                                  IsEnabled="{Binding IsStatsRealtimeEnabled}" />
                        <StackPanel Margin="0,6,0,0"
                                    Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                                       Text="Chu kỳ REST (giây):" />
                            <ComboBox MinWidth="72"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding StatsRealtimeIntervalChoices}"
                                      SelectedItem="{Binding StatsRealtimeIntervalSeconds}"
                                      IsEnabled="{Binding CanEditPollingInterval}" />
                            <TextBlock Margin="16,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeBodyTextBrush}"
                                       Text="Interval WS (ms):" />
                            <ComboBox MinWidth="72"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding StatsWebSocketIntervalChoices}"
                                      SelectedItem="{Binding StatsWebSocketIntervalMs}"
                                      IsEnabled="{Binding CanConfigureWebSocketInterval}" />
                        </StackPanel>
                        <TextBlock Margin="0,10,0,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeBodyTextBrush}"
                                   Text="Sparkline (CPU % và RAM % — tối đa 90 điểm)" />
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                           Text="CPU %" />
                                <Canvas Width="300"
                                        Height="72"
                                        Background="{DynamicResource ThemeSurfaceSubtleBrush}">
                                    <Polyline Stroke="{DynamicResource ThemeSparklineCpuStrokeBrush}"
                                              StrokeThickness="1.5"
                                              Points="{Binding CpuSparklinePoints}" />
                                </Canvas>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                           Text="RAM % (dùng/giới hạn)" />
                                <Canvas Width="300"
                                        Height="72"
                                        Background="{DynamicResource ThemeSurfaceSubtleBrush}">
                                    <Polyline Stroke="{DynamicResource ThemeSparklineMemStrokeBrush}"
                                              StrokeThickness="1.5"
                                              Points="{Binding MemorySparklinePoints}" />
                                </Canvas>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Gợi ý lệnh terminal (docker trên máy hoặc WSL)" />
                    <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Mở PowerShell hoặc WSL, dán lệnh. Lệnh attach thường cần container chạy với TTY; exec dùng shell mặc định sh (đổi thành bash hoặc cmd nếu image không có sh)." />
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="11"
                                           Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   Text="docker exec -it …" />
                        <StackPanel Margin="0,0,0,6"
                                    Orientation="Horizontal">
                            <TextBox MinWidth="280"
                                     Margin="0,0,8,0"
                                     Padding="6,4"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     Text="{Binding SuggestedExecCommandText, Mode=OneWay}" />
                            <Button Padding="10,6"
                                    VerticalAlignment="Center"
                                    Content="Sao chép"
                                    Command="{Binding CopySuggestedExecCommandCommand}" />
                        </StackPanel>
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="11"
                                    Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                                   Text="docker attach …" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox MinWidth="280"
                                     Margin="0,0,8,0"
                                     Padding="6,4"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     Text="{Binding SuggestedAttachCommandText, Mode=OneWay}" />
                            <Button Padding="10,6"
                                    VerticalAlignment="Center"
                                    Content="Sao chép"
                                    Command="{Binding CopySuggestedAttachCommandCommand}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Inspect (tóm tắt)" />
                    <TextBox MinHeight="100"
                             Margin="0,4,0,0"
                             Padding="8"
                             FontFamily="Segoe UI"
                             IsReadOnly="True"
                             Text="{Binding DetailInspectSummaryText}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Inspect (bảng chi tiết)" />
                    <TextBlock Margin="0,4,0,8"
                                           Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Mount, cổng (publish), mạng, biến môi trường và nhãn — sau khi nhấn «Tải chi tiết». Ô lọc chỉ áp dụng cho bảng nhãn." />
                    <TextBlock Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Mount" />
                    <DataGrid MaxHeight="160"
                              Margin="0,0,0,8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding DetailInspectMounts}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="80"
                                                Binding="{Binding Type}"
                                                Header="Loại" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="120"
                                                Binding="{Binding Source}"
                                                Header="Nguồn" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="120"
                                                Binding="{Binding Destination}"
                                                Header="Đích" />
                            <DataGridTextColumn Width="72"
                                                Binding="{Binding Mode}"
                                                Header="Mode" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Cổng (publish)" />
                    <DataGrid MaxHeight="140"
                              Margin="0,0,0,8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding DetailInspectPorts}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding ContainerPort}"
                                                Header="Cổng container" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding HostIp}"
                                                Header="Host IP" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="80"
                                                Binding="{Binding HostPort}"
                                                Header="Host port" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Mạng" />
                    <DataGrid MaxHeight="140"
                              Margin="0,0,0,8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding DetailInspectNetworks}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding Name}"
                                                Header="Tên" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="100"
                                                Binding="{Binding IpAddress}"
                                                Header="IP" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding Gateway}"
                                                Header="Gateway" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding MacAddress}"
                                                Header="MAC" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Biến môi trường (Env)" />
                    <DataGrid MaxHeight="180"
                              Margin="0,0,0,8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding DetailInspectEnv}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="200"
                                                Binding="{Binding Key}"
                                                Header="Khóa" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="160"
                                                Binding="{Binding Value}"
                                                Header="Giá trị" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Margin="0,0,0,4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Nhãn (Labels)" />
                    <TextBox Margin="0,0,0,6"
                             Text="{Binding InspectLabelFilterText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Lọc theo chuỗi trong tên hoặc giá trị nhãn (không phân biệt hoa thường)." />
                    <DataGrid MaxHeight="160"
                              Margin="0,0,0,8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding DetailInspectLabels}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="220"
                                                Binding="{Binding Key}"
                                                Header="Tên" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="160"
                                                Binding="{Binding Value}"
                                                Header="Giá trị" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Inspect (JSON thô)" />
                    <TextBox MinHeight="120"
                             Margin="0,4,0,0"
                             Padding="8"
                             FontFamily="Consolas"
                             IsReadOnly="True"
                             Text="{Binding DetailInspectJson}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Stats" />
                    <TextBox MinHeight="72"
                             Margin="0,4,0,0"
                             Padding="8"
                             FontFamily="Segoe UI"
                             IsReadOnly="True"
                             Text="{Binding DetailStatsText}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </ScrollViewer>
        </Expander>

        <WrapPanel Grid.Row="5"
                   Margin="0,10,0,8">
            <Button Content="Làm mới"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="100"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Chọn tất cả"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding SelectAllFilteredCommand}"
                    IsEnabled="{Binding CanSelectAllFiltered}" />
            <Button Content="Bỏ chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding ClearRowSelectionChecksCommand}"
                    IsEnabled="{Binding CanClearSelection}" />
            <Button Content="Start đã chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding BatchStartCommand}"
                    IsEnabled="{Binding CanBatchStart}" />
            <Button Content="Stop đã chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding BatchStopCommand}"
                    IsEnabled="{Binding CanBatchStop}" />
            <Button Content="Xóa đã chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding BatchRemoveCheckedCommand}"
                    IsEnabled="{Binding CanBatchRemove}" />
            <Button Content="Stats batch (chọn)"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="140"
                    Command="{Binding BatchStatsSnapshotCommand}"
                    IsEnabled="{Binding CanBatchStats}"
                    ToolTip="POST /api/containers/stats-batch — chọn ít nhất 2 hàng, tối đa 32; hiển thị CPU/RAM trong ô trạng thái." />
            <Button Content="Tải chi tiết"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="110"
                    Command="{Binding LoadDetailCommand}"
                    IsEnabled="{Binding CanLoadDetail}" />
            <Button Content="Start"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding StartSelectedCommand}"
                    IsEnabled="{Binding CanStart}" />
            <Button Content="Stop"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding StopSelectedCommand}"
                    IsEnabled="{Binding CanStop}" />
            <Button Content="Restart"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding RestartSelectedCommand}"
                    IsEnabled="{Binding CanRestart}" />
            <Button Content="Xóa"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="88"
                    Command="{Binding RemoveSelectedCommand}"
                    IsEnabled="{Binding CanRemove}" />
        </WrapPanel>

        <Border Grid.Row="6"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                Padding="12"
                CornerRadius="10">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeBodyTextBrush}" />
        </Border>
    </Grid>
</UserControl>
