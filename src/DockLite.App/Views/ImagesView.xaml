<UserControl x:Class="DockLite.App.Views.ImagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:DockLite.App.Converters"
             xmlns:behaviors="clr-namespace:DockLite.App.Behaviors"
             d:DesignHeight="560"
             d:DesignWidth="720"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Image"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemePageTitleBrush}"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1"
              Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     Margin="0,0,8,0"
                     ToolTip="Lọc theo repository, tag hoặc id" />
            <Button Grid.Column="1"
                    Content="Làm mới"
                    Padding="12,6"
                    MinWidth="100"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
        </Grid>

        <Grid Grid.Row="2"
              MinHeight="300"
              Margin="0,0,0,8">
            <Border behaviors:MouseWheelScrollBubbling.BubbleToMainContentScroll="True"
                    Style="{StaticResource RoundedTableChromeStyle}">
            <DataGrid ItemsSource="{Binding FilteredItems}"
                      SelectedItem="{Binding SelectedImage}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="48"
                                            Header="Chọn">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="*"
                                        Binding="{Binding Model.Repository}"
                                        Header="Repository"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTip" Value="{Binding Model.Repository}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="100"
                                        Binding="{Binding Model.Tag}"
                                        Header="Tag"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTip" Value="{Binding Model.Tag}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="160"
                                        Binding="{Binding Model.Id}"
                                        Header="Id"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTip" Value="{Binding Model.Id}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="90"
                                        Binding="{Binding Model.Size}"
                                        Header="Kích thước"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Width="140"
                                        Binding="{Binding Model.CreatedAt}"
                                        Header="Tạo"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
            </Border>
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="420"
                       Margin="16"
                       Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                       FontSize="13"
                       IsHitTestVisible="False"
                       Text="{DynamicResource Ui_Images_EmptyListHint}"
                       Visibility="{Binding ShowEmptyImageListHint, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="420"
                       Margin="16"
                       Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                       FontSize="13"
                       IsHitTestVisible="False"
                       Text="{DynamicResource Ui_Images_FilterEmptyHint}"
                       Visibility="{Binding ShowImageFilterEmptyHint, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <Expander Grid.Row="3"
                  Margin="0,0,0,10"
                  Foreground="{DynamicResource ThemeBodyTextBrush}"
                  Header="Chi tiết image (inspect, history, pull, export/import)"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}">
            <ScrollViewer MaxHeight="520"
                          behaviors:MouseWheelScrollBubbling.BubbleToMainContentScroll="True"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button Margin="0,0,8,4"
                                Padding="10,6"
                                Content="Tải inspect (JSON)"
                                Command="{Binding LoadInspectCommand}"
                                IsEnabled="{Binding IsDetailBusy, Converter={StaticResource InvertBooleanConverter}}" />
                        <Button Margin="0,0,8,4"
                                Padding="10,6"
                                Content="Tải history (layer)"
                                Command="{Binding LoadHistoryCommand}"
                                IsEnabled="{Binding IsDetailBusy, Converter={StaticResource InvertBooleanConverter}}" />
                    </StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Inspect" />
                    <TextBox MinHeight="120"
                             Margin="0,4,0,8"
                             Padding="8"
                             FontFamily="Consolas"
                             FontSize="11"
                             IsReadOnly="True"
                             Text="{Binding DetailInspectText}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="History (layer)" />
                    <DataGrid MaxHeight="200"
                              Margin="0,4,0,8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding HistoryRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding Id}"
                                                Header="Id" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding CreatedText}"
                                                Header="Tạo" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="160"
                                                Binding="{Binding CreatedBy}"
                                                Header="CreatedBy" />
                            <DataGridTextColumn Width="80"
                                                Binding="{Binding SizeText}"
                                                Header="Size" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding Comment}"
                                                Header="Comment" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Pull image (docker pull)" />
                    <TextBlock Margin="0,4,0,4"
                               Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Nhập reference đầy đủ (ví dụ nginx:latest). Log từ daemon có thể rút gọn." />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Margin="0,0,8,0"
                                 Text="{Binding PullReferenceText, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsDetailBusy, Converter={StaticResource InvertBooleanConverter}}" />
                        <Button Grid.Column="1"
                                Padding="12,6"
                                Content="Pull"
                                Command="{Binding PullImageCommand}"
                                IsEnabled="{Binding IsDetailBusy, Converter={StaticResource InvertBooleanConverter}}" />
                    </Grid>
                    <TextBlock Margin="0,0,0,4"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                               Text="Log pull" />
                    <TextBox MinHeight="80"
                             Margin="0,0,0,8"
                             Padding="8"
                             FontFamily="Consolas"
                             FontSize="11"
                             IsReadOnly="True"
                             Text="{Binding PullLogText}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeBodyTextBrush}"
                               Text="Export / import (docker save / load)" />
                    <TextBlock Margin="0,4,0,8"
                               Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Xuất: cần chọn một dòng image. Nhập: chọn file .tar từ docker save; có thể mất vài phút với image lớn." />
                    <StackPanel Orientation="Horizontal">
                        <Button Margin="0,0,8,4"
                                Padding="12,6"
                                Content="Xuất tar (image đang chọn)"
                                Command="{Binding ExportImageTarCommand}"
                                IsEnabled="{Binding IsDetailBusy, Converter={StaticResource InvertBooleanConverter}}" />
                        <Button Margin="0,0,8,4"
                                Padding="12,6"
                                Content="Nhập tar…"
                                Command="{Binding ImportImageTarCommand}"
                                IsEnabled="{Binding IsDetailBusy, Converter={StaticResource InvertBooleanConverter}}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Expander>

        <WrapPanel Grid.Row="4"
                   Margin="0,10,0,8">
            <Button Content="Chọn tất cả"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding SelectAllFilteredCommand}"
                    IsEnabled="{Binding CanSelectAllFiltered}" />
            <Button Content="Bỏ chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding ClearRowSelectionChecksCommand}"
                    IsEnabled="{Binding CanClearSelection}" />
            <Button Content="{DynamicResource Ui_Images_BatchCopyIds}"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    MinWidth="120"
                    Command="{Binding CopySelectedIdsToClipboardCommand}"
                    IsEnabled="{Binding CanCopySelectedIds}" />
            <Button Content="Xóa các dòng đã chọn"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding BatchRemoveCheckedCommand}"
                    IsEnabled="{Binding CanBatchRemove}" />
            <Button Content="Xóa image (dòng highlight)"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding RemoveSelectedCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Prune dangling"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding PruneDanglingCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            <Button Content="Prune mọi image không dùng (-a)"
                    Margin="0,0,8,4"
                    Padding="12,6"
                    Command="{Binding PruneAllUnusedCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
        </WrapPanel>

        <Border Grid.Row="5"
                BorderBrush="{DynamicResource ThemeSeparatorBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeBodyTextBrush}" />
        </Border>
    </Grid>
</UserControl>
