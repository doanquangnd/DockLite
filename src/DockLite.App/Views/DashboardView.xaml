<UserControl x:Class="DockLite.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="400"
             d:DesignWidth="640"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Tổng quan"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Service WSL"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <Border BorderBrush="#DDD"
                        BorderThickness="1"
                        Padding="12"
                        CornerRadius="4"
                        Margin="0,0,0,16">
                    <TextBlock Text="{Binding ServiceHealthText}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="Docker Engine"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <Border BorderBrush="#DDD"
                        BorderThickness="1"
                        Padding="12"
                        CornerRadius="4">
                    <TextBlock Text="{Binding DockerInfoText}"
                               TextWrapping="Wrap"
                               Foreground="#333"
                               FontFamily="Consolas" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Làm mới"
                    Padding="16,6"
                    MinWidth="120"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
        </StackPanel>
    </Grid>
</UserControl>
