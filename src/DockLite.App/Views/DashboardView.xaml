<UserControl x:Class="DockLite.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="400"
             d:DesignWidth="640"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Tổng quan"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemePageTitleBrush}"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="Service WSL"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeControlForegroundBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Padding="16"
                    CornerRadius="10"
                    Margin="0,0,0,20">
                <TextBlock Text="{Binding ServiceHealthText}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeBodyTextBrush}"
                           LineHeight="22" />
            </Border>

            <TextBlock Text="Docker Engine"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeControlForegroundBrush}"
                       Margin="0,0,0,8" />
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Padding="16"
                    CornerRadius="10">
                <TextBlock Text="{Binding DockerInfoText}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeCodeBlockForegroundBrush}"
                           FontFamily="Cascadia Mono, Consolas"
                           FontSize="12.5"
                           LineHeight="20" />
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="0,20,0,0">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource ThemeMutedForegroundBrush}"
                       FontSize="12"
                       Margin="0,0,0,10"
                       Text="Tự làm mới khi đang ở trang này và cửa sổ đang tương tác: chu kỳ ngắn hơn sau lần làm mới lỗi, dài hơn khi ổn định." />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Làm mới"
                        Padding="18,8"
                        MinWidth="128"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
